{{ 'divine-mockup-v3.css' | asset_url | stylesheet_tag }}

<section class="divine-newsletter">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'heading' -%}
        {%- if block.settings.heading != blank -%}
          <h2 {{ block.shopify_attributes }}>{{ block.settings.heading }}</h2>
        {%- endif -%}

      {%- when 'subtitle' -%}
        {%- if block.settings.text != blank -%}
          <p class="divine-newsletter__subtitle" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
        {%- endif -%}

      {%- when 'email_form' -%}
        <div {{ block.shopify_attributes }}>
          {%- form 'customer', id: 'DivineNewsletter', class: 'divine-newsletter__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input
              id="DivineNewsletterEmail--{{ section.id }}"
              type="email"
              name="contact[email]"
              value="{{ form.email }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="DivineNewsletter-error"
              {% elsif form.posted_successfully? %}
                aria-describedby="DivineNewsletter-success"
              {% endif %}
              placeholder="{{ section.settings.input_placeholder | default: 'Enter your email' }}"
              required
            >
            <button type="submit">{{ section.settings.button_label | default: 'Subscribe' }}</button>
          {%- endform -%}

          {%- if form.errors -%}
            <p class="divine-newsletter__message divine-newsletter__message--error" id="DivineNewsletter-error">
              {{ form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email }}
            </p>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <p class="divine-newsletter__message divine-newsletter__message--success" id="DivineNewsletter-success">
              {{ 'newsletter.success' | t }}
            </p>
          {%- endif -%}
        </div>
    {%- endcase -%}
  {%- endfor -%}

  {%- if section.settings.privacy_text != blank -%}
    <p class="divine-newsletter__privacy">{{ section.settings.privacy_text }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Divine Newsletter",
  "tag": "section",
  "class": "divine-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy disclaimer",
      "default": "No spam, ever. Unsubscribe anytime."
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Get 10% Off Your First Order"
        }
      ]
    },
    {
      "type": "subtitle",
      "name": "Subtitle",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subtitle text",
          "default": "Plus exclusive recipes, wellness tips, and early access to new products."
        }
      ]
    },
    {
      "type": "email_form",
      "name": "Email form",
      "limit": 1,
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Divine Newsletter",
      "blocks": [
        { "type": "heading" },
        { "type": "subtitle" },
        { "type": "email_form" }
      ]
    }
  ]
}
{% endschema %}
