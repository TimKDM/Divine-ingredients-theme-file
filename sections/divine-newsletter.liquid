{%- liquid
  assign heading_text = ''
  assign subtitle_text = ''
  for block in section.blocks
    case block.type
      when 'heading'
        assign heading_text = block.settings.heading
      when 'subtitle'
        assign subtitle_text = block.settings.text
    endcase
  endfor
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .d-email{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    padding-top: {{ section.settings.padding_top | default: 96 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 96 }}px;
    {% if section.settings.background_color != blank %}background:{{ section.settings.background_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .d-email .d-sec-h{
    font-size: {{ section.settings.heading_font_size | default: 52 }}px;
    {% if section.settings.text_color != blank %}color:{{ section.settings.text_color }};{% endif %}
  }
  {% if section.settings.text_color != blank %}
  #shopify-section-{{ section.id }} .d-email .d-email-desc,
  #shopify-section-{{ section.id }} .d-email .d-eperk{
    color: {{ section.settings.text_color }};
  }
  {% endif %}
  {% if section.settings.button_bg != blank %}
  #shopify-section-{{ section.id }} .d-email-btn{ background:{{ section.settings.button_bg }}; }
  {% endif %}
  {% if section.settings.button_color != blank %}
  #shopify-section-{{ section.id }} .d-email-btn{ color:{{ section.settings.button_color }}; }
  {% endif %}
{%- endstyle -%}

<section class="d-email d-reveal">
  <div>
    {%- if section.settings.caption != blank -%}
      <div class="d-sec-label">{{ section.settings.caption }}</div>
    {%- endif -%}
    {%- if heading_text != blank -%}
      <h2 class="d-sec-h">{{ heading_text }}</h2>
    {%- endif -%}
    {%- if subtitle_text != blank -%}
      <p class="d-email-desc">{{ subtitle_text }}</p>
    {%- endif -%}
  </div>
  <div>
    {%- if section.blocks.size > 0 -%}
      <div class="d-email-perks">
        {%- for block in section.blocks -%}
          {%- if block.type == 'perk' -%}
            <div class="d-eperk" {{ block.shopify_attributes }}>
              <div class="d-eperk-ck">✓</div>
              {{ block.settings.text }}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- form 'customer', class: 'd-email-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label for="DivineNewsletterEmail-{{ section.id }}" class="d-sr-only">Email address</label>
      {%- if section.settings.show_first_name -%}
        <label for="DivineNewsletterName-{{ section.id }}" class="d-sr-only">First name</label>
      {%- endif -%}
      <div class="d-email-row">
        {%- if section.settings.show_first_name -%}
          <input class="d-email-inp" id="DivineNewsletterName-{{ section.id }}" type="text" name="contact[first_name]" placeholder="{{ section.settings.name_placeholder | default: 'First name' }}" autocomplete="given-name" style="max-width:140px;border-right:1px solid var(--d-border)">
        {%- endif -%}
        <input class="d-email-inp" id="DivineNewsletterEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="{{ section.settings.input_placeholder | default: 'your@email.com' }}" autocomplete="email" required>
        <button class="d-email-btn" type="submit">{{ section.settings.button_label | default: 'Begin Your Ritual' }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="d-email-fine" style="color:var(--d-forest)">Thanks! Check your inbox for your welcome offer.</p>
      {%- elsif form.errors -%}
        <p class="d-email-fine" style="color:#a83232">{{ form.errors | default_errors }}</p>
      {%- else -%}
        <p class="d-email-fine">{{ section.settings.privacy_text | default: 'No spam. Unsubscribe anytime.' }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Newsletter",
  "tag": "section",
  "class": "divine-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Join the Divine World"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Email placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Begin Your Ritual"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy/fine print",
      "default": "No spam. Unsubscribe anytime."
    },
    {
      "type": "checkbox",
      "id": "show_first_name",
      "label": "Show first name field",
      "default": false
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "First name placeholder",
      "default": "First name"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 72,
      "step": 1,
      "default": 52,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Get 20% off your first order" }
      ]
    },
    {
      "type": "subtitle",
      "name": "Subtitle",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Subtitle text", "default": "New arrivals, recipes from our community, and seasonal drops. The good stuff only." }
      ]
    },
    {
      "type": "email_form",
      "name": "Email form",
      "limit": 1,
      "settings": []
    },
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        { "type": "text", "id": "text", "label": "Perk text", "default": "20% off your first order with code WELCOME" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Newsletter",
      "blocks": [
        { "type": "heading" },
        { "type": "subtitle" },
        { "type": "email_form" },
        { "type": "perk", "settings": { "text": "20% off your first order with code WELCOME" } },
        { "type": "perk", "settings": { "text": "Free shipping on orders over $100" } },
        { "type": "perk", "settings": { "text": "First access to new products & seasonal harvests" } }
      ]
    }
  ]
}
{% endschema %}
