{%- style -%}
  .divine-collection-hero {
    position: relative;
    min-height: 280px;
    display: flex;
    align-items: center;
    overflow: hidden;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  @media screen and (min-width: 750px) {
    .divine-collection-hero {
      min-height: 360px;
    }
  }
  .divine-collection-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .divine-collection-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .divine-collection-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      {{ section.settings.overlay_color | default: 'rgba(29,29,29,0.7)' }} 0%,
      {{ section.settings.overlay_color_end | default: 'rgba(29,29,29,0.3)' }} 100%
    );
    z-index: 1;
  }
  .divine-collection-hero__content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    padding: 48px 24px;
    color: {{ section.settings.text_color | default: '#ffffff' }};
  }
  @media screen and (min-width: 750px) {
    .divine-collection-hero__content {
      padding: 64px 48px;
    }
  }
  .divine-collection-hero__label {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.85;
  }
  .divine-collection-hero__title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 12px;
  }
  @media screen and (min-width: 750px) {
    .divine-collection-hero__title {
      font-size: 44px;
    }
  }
  .divine-collection-hero__desc {
    font-size: 16px;
    line-height: 1.7;
    opacity: 0.9;
    margin: 0 0 24px;
    max-width: 560px;
  }
  .divine-collection-hero__cta {
    display: inline-block;
    padding: 12px 28px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-sm, 4px);
    background: {{ section.settings.button_bg | default: '#ffffff' }};
    color: {{ section.settings.button_color | default: '#1d1d1d' }};
    transition: opacity 0.2s ease;
  }
  .divine-collection-hero__cta:hover {
    opacity: 0.85;
  }
{%- endstyle -%}

<section class="divine-collection-hero">
  <div class="divine-collection-hero__bg">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          widths: '375, 750, 1100, 1600',
          sizes: '100vw'
      }}
    {%- elsif collection.image -%}
      {{
        collection.image
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          widths: '375, 750, 1100, 1600',
          sizes: '100vw'
      }}
    {%- endif -%}
  </div>

  <div class="divine-collection-hero__content">
    {%- if section.settings.label != blank -%}
      <span class="divine-collection-hero__label">{{ section.settings.label }}</span>
    {%- endif -%}

    <h1 class="divine-collection-hero__title">
      {{ section.settings.heading | default: collection.title }}
    </h1>

    {%- if section.settings.description != blank -%}
      <p class="divine-collection-hero__desc">{{ section.settings.description }}</p>
    {%- elsif collection.description != blank -%}
      <div class="divine-collection-hero__desc">{{ collection.description }}</div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#shopify-section-product-grid' }}" class="divine-collection-hero__cta">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Collection Hero",
  "tag": "section",
  "class": "divine-collection-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Recommended 1600x600px. Falls back to collection image."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Category label",
      "info": "E.g. 'Green Tea Collection'"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use collection title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "info": "Leave blank to use collection description"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay start color",
      "default": "rgba(29,29,29,0.7)"
    },
    {
      "type": "color",
      "id": "overlay_color_end",
      "label": "Overlay end color",
      "default": "rgba(29,29,29,0.3)"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color",
      "default": "#1d1d1d"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Divine Collection Hero"
    }
  ]
}
{% endschema %}
