{%- comment -%}
  Divine Chai Edit. Dark CTA card with image right
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .d-discovery{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  #shopify-section-{{ section.id }} .d-disc-body{
    padding-top: {{ section.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 40 }}px;
    {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}background:{{ section.settings.background_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .d-disc-img-wrap{
    padding-top: {{ section.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 40 }}px;
  }
  #shopify-section-{{ section.id }} .d-disc-h{
    font-size: {{ section.settings.heading_font_size | default: 50 }}px;
  }
  #shopify-section-{{ section.id }} .d-disc-cta-form{ align-self: flex-start; margin: 0; }
{%- endstyle -%}

{%- liquid
  assign use_collage = false
  if section.settings.image_2 != blank or section.settings.image_3 != blank or section.settings.image_4 != blank
    assign use_collage = true
  endif
-%}

<section class="d-discovery d-reveal{% if use_collage %} d-discovery--collage{% endif %}">
  <div class="d-disc-img-wrap">
    {%- if use_collage -%}
      <div class="d-disc-collage">
        <div class="d-disc-tile">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 700 | image_tag:
              loading: 'lazy', widths: '350, 500, 700',
              sizes: '(min-width: 1100px) 25vw, 50vw',
              class: 'd-disc-tile-img', alt: section.settings.image.alt | default: section.settings.heading
            }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'd-disc-tile-img placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="d-disc-tile">
          {%- if section.settings.image_2 != blank -%}
            {{ section.settings.image_2 | image_url: width: 700 | image_tag:
              loading: 'lazy', widths: '350, 500, 700',
              sizes: '(min-width: 1100px) 25vw, 50vw',
              class: 'd-disc-tile-img', alt: section.settings.image_2.alt
            }}
          {%- else -%}
            {{ 'product-2' | placeholder_svg_tag: 'd-disc-tile-img placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="d-disc-tile">
          {%- if section.settings.image_3 != blank -%}
            {{ section.settings.image_3 | image_url: width: 700 | image_tag:
              loading: 'lazy', widths: '350, 500, 700',
              sizes: '(min-width: 1100px) 25vw, 50vw',
              class: 'd-disc-tile-img', alt: section.settings.image_3.alt
            }}
          {%- else -%}
            {{ 'product-3' | placeholder_svg_tag: 'd-disc-tile-img placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="d-disc-tile">
          {%- if section.settings.image_4 != blank -%}
            {{ section.settings.image_4 | image_url: width: 700 | image_tag:
              loading: 'lazy', widths: '350, 500, 700',
              sizes: '(min-width: 1100px) 25vw, 50vw',
              class: 'd-disc-tile-img', alt: section.settings.image_4.alt
            }}
          {%- else -%}
            {{ 'product-4' | placeholder_svg_tag: 'd-disc-tile-img placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag:
        loading: 'lazy', widths: '500, 750, 1000, 1400', sizes: '(min-width: 1100px) 50vw, 100vw',
        class: 'd-disc-img', alt: section.settings.image.alt | default: section.settings.heading
      }}
    {%- else -%}
      {{ 'product-2' | placeholder_svg_tag: 'd-disc-img placeholder-svg' }}
    {%- endif -%}
  </div>
  <div class="d-disc-body">
    {%- if section.settings.caption != blank -%}
      <div class="d-disc-label">{{ section.settings.caption }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank or section.settings.side_image != blank -%}
      <div class="d-disc-h-row">
        {%- if section.settings.side_image != blank -%}
          {{ section.settings.side_image | image_url: width: 200 | image_tag:
            loading: 'lazy', widths: '100, 150, 200',
            sizes: '80px',
            class: 'd-disc-side-img', alt: section.settings.side_image.alt | default: section.settings.heading
          }}
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="d-disc-h">{{ section.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="d-disc-p">{{ section.settings.text }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="d-disc-includes">
        {%- for block in section.blocks -%}
          {%- if block.type == 'include' -%}
            <div class="d-di" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.price != blank -%}
      <div class="d-disc-price-row">
        <div class="d-disc-price">{{ section.settings.price }}</div>
        {%- if section.settings.price_note != blank -%}
          <div class="d-disc-note">{{ section.settings.price_note }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      {%- comment -%}
        If a Chai Edit product is available (picked, or resolved by handle),
        the button adds it to the cart and lands on the cart page so the
        customer can check out. Until that product exists, fall back to a
        normal link (the cart) instead of a dead product URL.
      {%- endcomment -%}
      {%- liquid
        assign cta_product = section.settings.cta_product
        if cta_product == blank
          assign cta_handle = section.settings.cta_product_handle | default: 'the-chai-edit'
          assign cta_product = all_products[cta_handle]
        endif
      -%}
      {%- if cta_product != blank -%}
        <a href="{{ cta_product.url }}" class="d-btn-hp" style="align-self:flex-start">{{ section.settings.button_label }}</a>
      {%- else -%}
        <a href="{{ section.settings.button_link | default: '/cart' }}" class="d-btn-hp" style="align-self:flex-start">{{ section.settings.button_label }}</a>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.button_label_2 != blank -%}
      <a href="{{ section.settings.button_link_2 | default: '#' }}" class="d-btn-hg" style="align-self:flex-start;margin-top:16px">{{ section.settings.button_label_2 }} →</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Discovery",
  "tag": "section",
  "class": "divine-discovery-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image 1 (single image, or top-left collage tile)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (top-right tile) — adding this triggers 2×2 collage layout"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (bottom-left tile)"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4 (bottom-right tile)"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Side accent image (top of copy column — small badge/logo)"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption / kicker",
      "default": "New to Divine Ingredients?"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "<p>The <em>Chai Edit</em></p>"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Three of our most loved teas in one beautifully curated box. The easiest way to find your ritual. Without committing to a full size first."
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price (display)",
      "default": "$38"
    },
    {
      "type": "text",
      "id": "price_note",
      "label": "Price note",
      "default": "CAD"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get the Chai Edit"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Used only when no Chai Edit product is set/available below. Defaults to the cart."
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "info": "Optional. Shown as a lighter secondary link below the main button."
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    },
    {
      "type": "product",
      "id": "cta_product",
      "label": "Chai Edit product (button adds to cart)",
      "info": "When set, the button adds this product to the cart and goes to the cart page. Leave blank to auto-detect by handle below."
    },
    {
      "type": "text",
      "id": "cta_product_handle",
      "label": "Chai Edit product handle (auto-detect)",
      "default": "the-chai-edit",
      "info": "Fallback used if no product is picked above; the button activates automatically once a product with this handle is published."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Left-side background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 24,
      "max": 80,
      "step": 1,
      "default": 50,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "include",
      "name": "Included item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "3 handpicked bestselling teas" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Discovery",
      "blocks": [
        { "type": "include", "settings": { "text": "3 handpicked bestselling teas" } },
        { "type": "include", "settings": { "text": "USDA Organic · Lab tested" } },
        { "type": "include", "settings": { "text": "Perfect as a gift" } }
      ]
    }
  ]
}
{% endschema %}
