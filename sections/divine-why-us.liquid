{%- style -%}
  .d-why-section {
    --body-font-size: {{ section.settings.body_font_size | default: 14 }}px;
    --body-font-size-lg: {{ section.settings.body_font_size | default: 14 | plus: 1 }}px;
    --heading-font-size: {{ section.settings.heading_font_size | default: 26 }}px;
  }
  .d-why .d-sec-h {
    font-size: var(--heading-font-size);
  }
  .d-why-item h3 {
    font-size: {{ section.settings.item_heading_font_size | default: 16 }}px;
  }
  .d-why .d-sec-label {
    font-size: {{ section.settings.caption_font_size | default: 14 }}px;
  }
  .d-why-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  @media screen and (min-width: 768px) {
    .d-why-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}
    .d-why-section {
      background-color: {{ section.settings.background_color }};
    }
  {% endif %}
  {% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}
    .d-why h2,
    .d-why h3,
    .d-why p {
      color: {{ section.settings.text_color }};
    }
  {% endif %}
  {% if section.settings.accent_color != blank and section.settings.accent_color != 'rgba(0,0,0,0)' %}
    .d-why-icon svg {
      stroke: {{ section.settings.accent_color }};
    }
  {% endif %}
{%- endstyle -%}

<section class="d-why{% if section.settings.use_alt_bg %} d-sec-alt{% endif %}">
  {%- if section.settings.heading != blank -%}
    <div class="d-sec-header">
      {%- if section.settings.caption != blank -%}
        <span class="d-sec-label">{{ section.settings.caption }}</span>
      {%- endif -%}
      <h2 class="d-sec-h">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="d-why-grid">
    {%- for block in section.blocks -%}
      <div class="d-why-item" {{ block.shopify_attributes }}>
        <div class="d-why-icon">
          {%- case block.settings.icon -%}
            {%- when 'leaf' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"></path>
                <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
              </svg>
            {%- when 'globe' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            {%- when 'clipboard' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
              </svg>
            {%- when 'heart' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
          {%- endcase -%}
        </div>
        {%- if block.settings.title != blank -%}
          <h3>{{ block.settings.title }}</h3>
        {%- endif -%}
        {%- if block.settings.description != blank -%}
          <p>{{ block.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.cta_label != blank -%}
    <div class="d-why-cta">
      <a href="{{ section.settings.cta_link }}" class="d-btn-t">{{ section.settings.cta_label }}</a>
    </div>
  {%- endif -%}
</section>

<style>
  .d-why {
    padding: 48px 20px;
    text-align: center;
  }
  .d-why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 1000px;
    margin: 32px auto 0;
  }
  .d-why-item {
    text-align: center;
    padding: 24px 16px;
  }
  .d-why-icon {
    margin-bottom: 16px;
  }
  .d-why-icon svg {
    width: 48px;
    height: 48px;
    stroke: var(--color-accent-dark, #7c6c5b);
    stroke-width: 1.5;
    fill: none;
  }
  .d-why-item h3 {
    font-family: var(--d-font-serif);
    font-size: {{ section.settings.item_heading_font_size | default: 16 }}px;
    font-weight: 600;
    margin: 0 0 8px;
    letter-spacing: 0.02em;
  }
  .d-why-item p {
    font-size: var(--body-font-size);
    color: var(--color-text-muted, #666);
    line-height: 1.6;
    margin: 0;
    max-width: 300px;
    margin-left: auto;
    margin-right: auto;
  }
  .d-why-cta {
    text-align: center;
    margin-top: 32px;
  }
  @media screen and (min-width: 750px) {
    .d-why-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }
    .d-why-icon svg {
      width: 56px;
      height: 56px;
    }
    .d-why-item h3 {
      font-size: {{ section.settings.item_heading_font_size | default: 16 | plus: 2 }}px;
    }
    .d-why-item p {
      font-size: var(--body-font-size-lg);
    }
  }
</style>

{% schema %}
{
  "name": "Why Divine",
  "tag": "section",
  "class": "d-why-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Divine Ingredients"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Learn About Our Ingredients"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / icon color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 56,
      "step": 1,
      "default": 26,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Caption font size",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "item_heading_font_size",
      "label": "Item/card title font size",
      "min": 12,
      "max": 36,
      "step": 1,
      "default": 16,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf", "label": "Leaf / Organic" },
            { "value": "globe", "label": "Globe / Sourcing" },
            { "value": "shield", "label": "Shield / Quality" },
            { "value": "clipboard", "label": "Clipboard / Tested" },
            { "value": "heart", "label": "Heart / Care" }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Organic Ingredients"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "No fillers, additives, or artificial flavors."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Divine",
      "blocks": [
        { "type": "feature", "settings": { "icon": "leaf", "title": "100% Organic Ingredients", "description": "No fillers, additives, or artificial flavors." } },
        { "type": "feature", "settings": { "icon": "globe", "title": "Ethically Sourced", "description": "Direct relationships with farms worldwide." } },
        { "type": "feature", "settings": { "icon": "shield", "title": "Tested for Quality", "description": "Microbiologically tested for purity and safety." } }
      ]
    }
  ]
}
{% endschema %}
