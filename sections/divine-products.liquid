{%- style -%}
  #shopify-section-{{ section.id }} .d-products{
    {% if section.settings.background_color != blank %}background-color: {{ section.settings.background_color }};{% endif %}
    padding-top: {{ section.settings.padding_top | default: 96 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 96 }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  #shopify-section-{{ section.id }} .d-pcard-name{
    font-size: {{ section.settings.body_font_size | default: 20 }}px;
  }
  #shopify-section-{{ section.id }} .d-sec-h{
    font-size: {{ section.settings.heading_font_size | default: 52 }}px;
  }
  #shopify-section-{{ section.id }} .d-sec-label{
    font-size: {{ section.settings.caption_font_size | default: 11 }}px;
    {% if section.settings.accent_color != blank %}color: {{ section.settings.accent_color }};{% endif %}
  }
  {% if section.settings.text_color != blank %}
  #shopify-section-{{ section.id }} .d-sec-h,
  #shopify-section-{{ section.id }} .d-pcard-name,
  #shopify-section-{{ section.id }} .d-pcard-price{
    color: {{ section.settings.text_color }};
  }
  {% endif %}
  {% if section.settings.card_background_color != blank %}
  #shopify-section-{{ section.id }} .d-pcard{
    background-color: {{ section.settings.card_background_color }};
  }
  {% endif %}
{%- endstyle -%}

{%- assign collection = collections[section.settings.collection] -%}
{%- assign limit = section.settings.products_to_show | default: 4 -%}

<section class="d-products d-reveal">
  <div class="d-prod-header">
    <div>
      {%- if section.settings.caption != blank -%}
        <div class="d-sec-label">{{ section.settings.caption }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="d-sec-h">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.show_view_all -%}
      {%- assign view_link = section.settings.view_all_link -%}
      {%- if view_link == blank and collection != blank -%}{%- assign view_link = collection.url -%}{%- endif -%}
      <a href="{{ view_link | default: '/collections/all' }}" class="d-btn-t" style="flex-shrink:0;margin-bottom:8px">{{ section.settings.view_all_label | default: 'View all products' }} →</a>
    {%- endif -%}
  </div>

  <div class="d-prod-grid">
    {%- if collection != blank and collection.products.size > 0 -%}
      {%- for product in collection.products limit: limit -%}
        {%- assign subtitle_meta = product.metafields.custom.subtitle | default: product.type -%}
        <a href="{{ product.url }}" class="d-pcard">
          <div class="d-pcard-img-wrap">
            {%- if product.featured_image != blank -%}
              {{ product.featured_image | image_url: width: 800 | image_tag:
                loading: 'lazy', widths: '300, 500, 700', sizes: '(min-width: 1100px) 25vw, 50vw',
                class: 'd-pcard-img', alt: product.featured_image.alt | default: product.title
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'd-pcard-img placeholder-svg' }}
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <div class="d-pbadge d-pbadge-sale">Sale</div>
            {%- elsif product.tags contains 'best-seller' or product.tags contains 'Best Seller' -%}
              <div class="d-pbadge d-pbadge-dk">Best Seller</div>
            {%- elsif product.tags contains 'customer-favorite' or product.tags contains 'Customer Fav' -%}
              <div class="d-pbadge d-pbadge-gd">Customer Fav</div>
            {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
              <div class="d-pbadge d-pbadge-dk">New</div>
            {%- endif -%}
          </div>
          <div class="d-pcard-body">
            {%- if subtitle_meta != blank -%}
              <div class="d-pcard-cat">{{ subtitle_meta }}</div>
            {%- endif -%}
            <h3 class="d-pcard-name">{{ product.title }}</h3>
            <div class="d-pcard-note">
              {%- if product.metafields.custom.tagline != blank -%}
                {{ product.metafields.custom.tagline }}
              {%- else -%}
                <span class="d-hi">USDA Organic · Lab tested</span>
              {%- endif -%}
            </div>
            <div class="d-pcard-foot">
              <div>
                <div class="d-pcard-price">
                  {%- if product.price_varies -%}
                    From {{ product.price_min | money_without_trailing_zeros }}
                  {%- else -%}
                    {{ product.price | money_without_trailing_zeros }}
                  {%- endif -%}
                  {%- if product.compare_at_price > product.price -%}
                    <s>{{ product.compare_at_price | money_without_trailing_zeros }}</s>
                  {%- endif -%}
                </div>
                <div class="d-pcard-sz">{{ cart.currency.iso_code }}</div>
              </div>
              <span class="d-pcard-add" aria-hidden="true">+</span>
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="d-pcard">
          <div class="d-pcard-img-wrap">
            {{ 'product-' | append: i | placeholder_svg_tag: 'd-pcard-img placeholder-svg' }}
            <div class="d-pbadge d-pbadge-dk">Best Seller</div>
          </div>
          <div class="d-pcard-body">
            <div class="d-pcard-cat">Sample category</div>
            <h3 class="d-pcard-name">Sample Product {{ i }}</h3>
            <div class="d-pcard-note">Ceremonial grade. <span class="d-hi">USDA Organic · Lab tested</span></div>
            <div class="d-pcard-foot">
              <div>
                <div class="d-pcard-price">{{ 3000 | money_without_trailing_zeros }}</div>
                <div class="d-pcard-sz">{{ cart.currency.iso_code }}</div>
              </div>
              <span class="d-pcard-add" aria-hidden="true">+</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>


{% schema %}
{
  "name": "Divine Products",
  "tag": "section",
  "class": "divine-products-section",
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Customer Favorites"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The ones people keep coming back for"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating (legacy)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "Show product tags",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View all products"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Card name size",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 72,
      "step": 1,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Caption font size",
      "min": 8,
      "max": 18,
      "step": 1,
      "default": 11,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Divine Products",
      "settings": {
        "title": "The ones people keep coming back for",
        "caption": "Customer Favorites"
      }
    }
  ]
}
{% endschema %}
