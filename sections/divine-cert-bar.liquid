{%- style -%}
  .divine-cert-bar-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
  }
  @media screen and (min-width: 768px) {
    .divine-cert-bar-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="divine-cert-bar{% if section.settings.use_alt_bg %} divine-section-alt{% endif %}">
  {%- if section.settings.heading != blank -%}
    <p class="divine-cert-bar__heading">{{ section.settings.heading }}</p>
  {%- endif -%}

  <div class="divine-cert-bar__icons">
    {%- for block in section.blocks -%}
      <div class="divine-cert-bar__item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 120
            | image_tag:
              loading: 'lazy',
              width: 60,
              height: 60,
              class: 'divine-cert-bar__logo'
          }}
        {%- else -%}
          <div class="divine-cert-bar__icon">
            {%- case block.settings.icon -%}
              {%- when 'usda' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/><path d="M14 28V20h2c2.5 0 3.5 1 3.5 2.5S18.5 25 16 25h-1v3h-1zm1-4h1c1.7 0 2.5-.6 2.5-1.5S17.7 21 16 21h-1v3z" fill="currentColor"/><text x="24" y="32" text-anchor="middle" font-size="7" font-weight="600" fill="currentColor">USDA</text><text x="24" y="18" text-anchor="middle" font-size="5" fill="currentColor">ORGANIC</text></svg>
              {%- when 'ccof' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/><text x="24" y="27" text-anchor="middle" font-size="9" font-weight="700" fill="currentColor">CCOF</text><text x="24" y="35" text-anchor="middle" font-size="5" fill="currentColor">CERTIFIED</text></svg>
              {%- when 'non-gmo' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/><text x="24" y="22" text-anchor="middle" font-size="6" font-weight="600" fill="currentColor">NON</text><text x="24" y="30" text-anchor="middle" font-size="7" font-weight="700" fill="currentColor">GMO</text></svg>
              {%- when 'lab-tested' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/><path d="M20 14v10l-4 8h16l-4-8V14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="18" y1="14" x2="30" y2="14" stroke="currentColor" stroke-width="1.5"/><circle cx="22" cy="28" r="1.5" fill="currentColor"/><circle cx="27" cy="30" r="1" fill="currentColor"/></svg>
              {%- when 'vegan' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/><path d="M17 32c0-8 4-16 14-18-1 6-3 10-6 13s-5 4-8 5z" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.5"/><text x="24" y="38" text-anchor="middle" font-size="5" font-weight="600" fill="currentColor">VEGAN</text></svg>
              {%- when 'fair-trade' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/><path d="M16 24h16M24 16v16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><text x="24" y="38" text-anchor="middle" font-size="4.5" font-weight="600" fill="currentColor">FAIR TRADE</text></svg>
              {%- when 'kosher' -%}
                <svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.5"/><text x="24" y="28" text-anchor="middle" font-size="11" font-weight="700" fill="currentColor">K</text><text x="24" y="37" text-anchor="middle" font-size="4.5" font-weight="600" fill="currentColor">KOSHER</text></svg>
            {%- endcase -%}
          </div>
        {%- endif -%}
        {%- if block.settings.label != blank -%}
          <span class="divine-cert-bar__label">{{ block.settings.label }}</span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

<style>
  .divine-cert-bar {
    text-align: center;
    padding: 32px 20px;
  }
  .divine-cert-bar__heading {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted, #888);
    margin: 0 0 20px;
  }
  .divine-cert-bar__icons {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 32px;
    max-width: 800px;
    margin: 0 auto;
  }
  @media screen and (max-width: 749px) {
    .divine-cert-bar__icons {
      gap: 20px;
    }
  }
  .divine-cert-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .divine-cert-bar__logo {
    width: 52px;
    height: 52px;
    object-fit: contain;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  .divine-cert-bar__logo:hover {
    opacity: 1;
  }
  .divine-cert-bar__icon {
    width: 52px;
    height: 52px;
    color: var(--color-text-muted, #888);
    transition: color 0.2s ease;
  }
  .divine-cert-bar__icon:hover {
    color: var(--color-text, #333);
  }
  .divine-cert-bar__icon svg {
    width: 100%;
    height: 100%;
  }
  .divine-cert-bar__label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted, #888);
  }
</style>

{% schema %}
{
  "name": "Divine Certifications",
  "tag": "section",
  "class": "divine-cert-bar-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted & Certified"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "cert",
      "name": "Certification",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "usda", "label": "USDA Organic" },
            { "value": "ccof", "label": "CCOF Certified" },
            { "value": "non-gmo", "label": "Non-GMO" },
            { "value": "lab-tested", "label": "Lab Tested" },
            { "value": "vegan", "label": "Vegan" },
            { "value": "fair-trade", "label": "Fair Trade" },
            { "value": "kosher", "label": "Kosher" }
          ],
          "default": "usda"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom logo (overrides icon)",
          "info": "Upload actual cert logos for best results. 120x120px recommended."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (optional)",
          "info": "Short text below the icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Certifications",
      "blocks": [
        { "type": "cert", "settings": { "icon": "usda", "label": "USDA Organic" } },
        { "type": "cert", "settings": { "icon": "ccof", "label": "CCOF Certified" } },
        { "type": "cert", "settings": { "icon": "non-gmo", "label": "Non-GMO" } },
        { "type": "cert", "settings": { "icon": "lab-tested", "label": "Lab Tested" } },
        { "type": "cert", "settings": { "icon": "vegan", "label": "Vegan" } }
      ]
    }
  ]
}
{% endschema %}
