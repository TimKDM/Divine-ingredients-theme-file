{%- style -%}
  #shopify-section-{{ section.id }} .d-certs{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    padding-top: {{ section.settings.padding_top | default: 28 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 28 }}px;
    {% if section.settings.background_color != blank %}background:{{ section.settings.background_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .d-cert{
    font-size: {{ section.settings.body_font_size | default: 11 }}px;
  }
  #shopify-section-{{ section.id }} .d-certs-label{
    font-size: {{ section.settings.heading_font_size | default: 10 }}px;
  }
{%- endstyle -%}

<div class="d-certs d-reveal">
  {%- if section.settings.heading != blank -%}
    <div class="d-certs-label">{{ section.settings.heading }}</div>
  {%- endif -%}
  {%- for block in section.blocks -%}
    <div class="d-cert" {{ block.shopify_attributes }}>
      <div class="d-cert-dot"></div>
      {{- block.settings.label -}}
    </div>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Divine Cert Bar",
  "tag": "section",
  "class": "divine-cert-bar-section",
  "max_blocks": 16,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading / label",
      "default": "Certified by"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 28,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Pill text size",
      "min": 8,
      "max": 18,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Label size",
      "min": 8,
      "max": 18,
      "step": 1,
      "default": 10,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "cert",
      "name": "Certification",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "USDA Organic" },
        { "type": "image_picker", "id": "image", "label": "Logo (legacy, unused)" },
        { "type": "select", "id": "icon", "label": "Icon (legacy, unused)",
          "options": [
            { "value": "usda", "label": "USDA" },
            { "value": "ccof", "label": "CCOF" },
            { "value": "non-gmo", "label": "Non-GMO" },
            { "value": "lab-tested", "label": "Lab Tested" },
            { "value": "vegan", "label": "Vegan" },
            { "value": "fair-trade", "label": "Fair Trade" },
            { "value": "rainforest", "label": "Rainforest Alliance" },
            { "value": "kosher", "label": "Kosher" }
          ], "default": "usda" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Cert Bar",
      "blocks": [
        { "type": "cert", "settings": { "label": "USDA Organic" } },
        { "type": "cert", "settings": { "label": "CCOF Certified" } },
        { "type": "cert", "settings": { "label": "Lab Tested Every Batch" } },
        { "type": "cert", "settings": { "label": "Non-GMO" } },
        { "type": "cert", "settings": { "label": "Fair Trade" } },
        { "type": "cert", "settings": { "label": "Rainforest Alliance" } },
        { "type": "cert", "settings": { "label": "Woman Owned" } }
      ]
    }
  ]
}
{% endschema %}
