{%- style -%}
  .divine-subscription-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  @media screen and (min-width: 768px) {
    .divine-subscription-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}
    .divine-subscription {
      background-color: {{ section.settings.background_color }};
    }
  {% endif %}
{%- endstyle -%}

<section class="divine-subscription{% if section.settings.use_alt_bg %} divine-section-alt{% endif %}">
  <div class="divine-section-header">
    {%- if section.settings.caption != blank -%}
      <span class="divine-section-label">{{ section.settings.caption }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="divine-section-title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="divine-subscription__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="divine-subscription__grid">
    {%- for block in section.blocks -%}
      <div class="divine-subscription__card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <div class="divine-subscription__card-image">
            {{
              block.settings.image
              | image_url: width: 500
              | image_tag:
                loading: 'lazy',
                widths: '200, 300, 400, 500',
                sizes: '(min-width: 768px) 33vw, 100vw'
            }}
          </div>
        {%- else -%}
          <div class="divine-subscription__card-image divine-subscription__card-image--placeholder">
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        <div class="divine-subscription__card-content">
          {%- if block.settings.title != blank -%}
            <h3>{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p>{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.price != blank -%}
            <span class="divine-subscription__price">{{ block.settings.price }}</span>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link }}" class="divine-btn divine-btn-primary divine-btn--small">{{ block.settings.button_label }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.settings.cta_label != blank -%}
    <div class="divine-subscription__footer-cta">
      <a href="{{ section.settings.cta_link }}" class="divine-btn divine-btn-secondary">{{ section.settings.cta_label }}</a>
    </div>
  {%- endif -%}
</section>

<style>
  .divine-subscription {
    padding: 48px 20px;
    text-align: center;
  }
  .divine-subscription__subheading {
    font-size: 15px;
    color: var(--color-text-muted, #666);
    max-width: 560px;
    margin: 8px auto 0;
    line-height: 1.6;
  }
  .divine-subscription__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 1000px;
    margin: 32px auto 0;
  }
  .divine-subscription__card {
    background: var(--color-background-hex, #fff);
    border-radius: var(--radius-md, 10px);
    overflow: hidden;
    border: 1px solid var(--color-border-hex, #d2c4d7);
    text-align: left;
    transition: box-shadow 0.28s ease, transform 0.28s ease;
  }
  .divine-subscription__card:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  .divine-subscription__card-image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  .divine-subscription__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .divine-subscription__card:hover .divine-subscription__card-image img {
    transform: scale(1.03);
  }
  .divine-subscription__card-image--placeholder {
    background: var(--color-background-alt, #e2d6e6);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .divine-subscription__card-content {
    padding: 20px;
  }
  .divine-subscription__card-content h3 {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 6px;
  }
  .divine-subscription__card-content p {
    font-size: 14px;
    color: var(--color-text-muted, #7a6f64);
    line-height: 1.6;
    margin: 0 0 12px;
  }
  .divine-subscription__price {
    display: block;
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 14px;
    color: var(--color-accent-dark, #9b76a7);
  }
  .divine-subscription__card .divine-btn--small {
    padding: 10px 20px;
    font-size: 13px;
  }
  .divine-subscription__footer-cta {
    text-align: center;
    margin-top: 28px;
  }
  @media screen and (min-width: 750px) {
    .divine-subscription__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Divine Subscriptions",
  "tag": "section",
  "class": "divine-subscription-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Subscribe & Save"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Divine Ritual"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Never run out of your favorites. Subscribe monthly and save 15% on every delivery."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Footer CTA label",
      "default": "Save 15% Monthly"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Footer CTA link"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "plan",
      "name": "Subscription Plan",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Plan name",
          "default": "Monthly Tea Box"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "A curated selection of seasonal loose leaf teas delivered to your door every month."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price text",
          "default": "From $29/month"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Start My Subscription"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Subscriptions",
      "blocks": [
        { "type": "plan", "settings": { "title": "Monthly Tea Box", "description": "A curated selection of seasonal loose leaf teas delivered to your door every month.", "price": "From $29/month", "button_label": "Start My Subscription" } },
        { "type": "plan", "settings": { "title": "Superfood Powder Club", "description": "Your monthly dose of organic superfood powders — adaptogens, mushrooms, and more.", "price": "From $34/month", "button_label": "Start My Subscription" } },
        { "type": "plan", "settings": { "title": "Matcha of the Month", "description": "Explore a different premium matcha grade each month from Japan's finest farms.", "price": "From $24/month", "button_label": "Start My Subscription" } }
      ]
    }
  ]
}
{% endschema %}
