{%- liquid
  assign kicker_text = ''
  assign btn1_label = ''
  assign btn1_link = ''
  assign btn2_label = ''
  assign btn2_link = ''
  for block in section.blocks
    case block.type
      when 'badge'
        assign kicker_text = block.settings.text
      when 'buttons'
        assign btn1_label = block.settings.button_label_1
        assign btn1_link = block.settings.button_link_1
        assign btn2_label = block.settings.button_label_2
        assign btn2_link = block.settings.button_link_2
    endcase
  endfor
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .d-hero{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    {% if section.settings.image_height != blank and section.settings.image_height != 0 %}
      height: {{ section.settings.image_height }}vh;
    {% endif %}
  }
  {% if section.settings.overlay_opacity != blank %}
    #shopify-section-{{ section.id }} .d-hero-overlay{
      opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    }
  {% endif %}
  /* "Ready to discover?" prompt chip (fades in after a delay, click to open the Chai Edit modal) */
  #shopify-section-{{ section.id }} .d-hero-prompt{
    position: absolute; bottom: 28px; right: 28px; z-index: 5;
    display: flex; align-items: center; gap: 8px;
    opacity: 0; visibility: hidden; transform: translateY(10px); pointer-events: none;
    transition: opacity .45s ease, transform .45s ease, visibility .45s;
  }
  #shopify-section-{{ section.id }} .d-hero-prompt.is-visible{
    opacity: 1; visibility: visible; transform: none; pointer-events: auto;
  }
  #shopify-section-{{ section.id }} .d-hero-prompt__btn{
    background: var(--d-beige-lt); color: var(--d-black); border: none;
    border-radius: 100px; padding: 13px 24px; cursor: pointer;
    font-family: var(--d-font-sans); font-size: 13px; font-weight: 500; letter-spacing: .04em;
    box-shadow: 0 8px 28px rgba(0,0,0,.28); transition: transform .12s;
  }
  #shopify-section-{{ section.id }} .d-hero-prompt__btn:hover{ transform: translateY(-1px); }
  #shopify-section-{{ section.id }} .d-hero-prompt__dismiss{
    background: rgba(17,20,16,.5); color: #fff; border: none; border-radius: 50%;
    width: 26px; height: 26px; font-size: 16px; line-height: 1; cursor: pointer; padding: 0;
  }
  @media(max-width: 720px){
    #shopify-section-{{ section.id }} .d-hero-prompt{ bottom: 18px; right: 18px; }
  }
{%- endstyle -%}

<section class="d-hero">
  {%- if section.settings.video != blank -%}
    {%- assign poster_url = section.settings.image | image_url: width: 1500 -%}
    <video
      class="d-hero-media"
      {% if section.settings.autoplay %}autoplay{% endif %}
      {% if section.settings.loop %}loop{% endif %}
      {% if section.settings.muted %}muted{% endif %}
      playsinline
      preload="metadata"
      {% if poster_url != blank %}poster="{{ poster_url }}"{% endif %}
    >
      {%- for source in section.settings.video.sources -%}
        <source src="{{ source.url }}" type="{{ source.mime_type }}">
      {%- endfor -%}
    </video>
  {%- elsif section.settings.video_url != blank -%}
    <div class="d-hero-media">
      {{ section.settings.video_url | external_video_url: autoplay: section.settings.autoplay, loop: section.settings.loop, muted: section.settings.muted | external_video_tag: loading: 'lazy', class: 'd-hero-media' }}
    </div>
  {%- elsif section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag:
      loading: 'eager',
      widths: '750, 1000, 1500, 2000',
      sizes: '100vw',
      class: 'd-hero-media',
      alt: section.settings.image.alt | default: shop.name
    }}
  {%- else -%}
    <div class="d-hero-media" style="background:linear-gradient(135deg,#1F3018,#111410);"></div>
  {%- endif -%}

  <div class="d-hero-overlay"></div>

  <div class="d-hero-content">
    {%- if kicker_text != blank -%}
      <div class="d-hero-kicker">{{ kicker_text }}</div>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="d-hero-h1">{{ section.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h1>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="d-hero-p">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if btn1_label != blank or btn2_label != blank -%}
      <div class="d-hero-btns">
        {%- if btn1_label != blank -%}
          <a href="{{ btn1_link | default: '#' }}" class="d-btn-hp">{{ btn1_label }}</a>
        {%- endif -%}
        {%- if btn2_label != blank -%}
          <a href="{{ btn2_link | default: '#' }}" class="d-btn-hg">{{ btn2_label }} →</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if section.settings.enable_chai_prompt -%}
    <div class="d-hero-prompt" data-prompt-delay="{{ section.settings.prompt_delay | default: 5 }}">
      <button type="button" class="d-hero-prompt__btn" data-open-chai-popup>{{ section.settings.prompt_label | default: 'Ready to discover?' }}</button>
      <button type="button" class="d-hero-prompt__dismiss" aria-label="Dismiss">&times;</button>
    </div>
    {% render 'chai-edit-popup' %}
  {%- endif -%}
</section>

{%- if section.settings.enable_chai_prompt -%}
<script>
  (function(){
    var prompt = document.querySelector('.d-hero-prompt');
    if (!prompt || prompt.dataset.bound) return;
    prompt.dataset.bound = '1';
    var KEY = 'dChaiPromptSeen';
    try { if (sessionStorage.getItem(KEY)) return; } catch (e) {}

    var delay = (parseFloat(prompt.getAttribute('data-prompt-delay')) || 5) * 1000;
    var dismissBtn = prompt.querySelector('.d-hero-prompt__dismiss');
    var openBtn = prompt.querySelector('.d-hero-prompt__btn');
    var hero = prompt.closest('.d-hero') || prompt;
    var shown = false, timer = null;

    function reveal(){ if (!shown) { shown = true; prompt.classList.add('is-visible'); } }
    function markSeen(){ try { sessionStorage.setItem(KEY, '1'); } catch (e) {} }
    function hide(){ prompt.classList.remove('is-visible'); }

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(en){
          if (en.isIntersecting && !timer && !shown) { timer = setTimeout(reveal, delay); }
        });
      }, { threshold: 0.25 });
      io.observe(hero);
    } else {
      timer = setTimeout(reveal, delay);
    }

    if (dismissBtn) dismissBtn.addEventListener('click', function(){ hide(); markSeen(); });
    // Opening the modal (handled by the snippet via [data-open-chai-popup]) also retires the chip for the session
    if (openBtn) openBtn.addEventListener('click', function(){ hide(); markSeen(); });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Divine Hero",
  "tag": "section",
  "class": "divine-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Used as poster while the video loads, and as the fallback when no video is set"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video (upload)",
      "info": "Preferred. Plays inline at fullscreen behind the hero copy. Falls back to image."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background video URL (YouTube/Vimeo)",
      "info": "Used only when no video file is uploaded above."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute video",
      "default": true
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Honest<br>ingredients.<br><em>Nothing more.</em></p>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Teas, superfoods, and botanicals sourced directly from the farms we know. Tested before they reach you. No filters, no synthetics, no guesswork."
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Hero height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 95,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 120,
      "step": 2,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Badge font size",
      "min": 8,
      "max": 22,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Chai Edit prompt"
    },
    {
      "type": "checkbox",
      "id": "enable_chai_prompt",
      "label": "Show \"Ready to discover?\" prompt",
      "info": "Fades in over the hero after a delay; opens the Chai Edit pop-up on click.",
      "default": true
    },
    {
      "type": "text",
      "id": "prompt_label",
      "label": "Prompt label",
      "default": "Ready to discover?"
    },
    {
      "type": "range",
      "id": "prompt_delay",
      "label": "Prompt delay",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 5,
      "unit": "s"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "USDA Organic · CCOF Certified · Lab Tested Every Batch"
        },
        {
          "type": "color",
          "id": "badge_bg",
          "label": "Badge background"
        },
        {
          "type": "color",
          "id": "badge_color",
          "label": "Badge text color"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": []
    },
    {
      "type": "subtitle",
      "name": "Subtitle",
      "limit": 1,
      "settings": []
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label_1",
          "label": "Primary button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link_1",
          "label": "Primary button link"
        },
        {
          "type": "color",
          "id": "btn1_bg",
          "label": "Primary button background"
        },
        {
          "type": "color",
          "id": "btn1_color",
          "label": "Primary button text color"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Secondary button label",
          "default": "Find Your Blend"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Secondary button link"
        },
        {
          "type": "color",
          "id": "btn2_color",
          "label": "Secondary button color"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Hero",
      "blocks": [
        { "type": "badge" },
        { "type": "heading" },
        { "type": "subtitle" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}
