{{ 'swiper.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper.min.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #shopify-section-{{ section.id }} .d-hero{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    {% if section.settings.image_height != blank and section.settings.image_height != 0 %}
      height: {{ section.settings.image_height }}vh;
    {% endif %}
  }
  /* Slider: each slide replicates the hero frame (full-bleed media + bottom copy) */
  #shopify-section-{{ section.id }} .d-hero--slider{ display: block; }
  #shopify-section-{{ section.id }} .d-hero--slider .swiper,
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-wrapper,
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide{ height: 100%; width: 100%; }
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide{
    position: relative; display: flex; align-items: flex-end;
    overflow: hidden; background: var(--d-black);
  }
  /* Media brightness fix — override the global .d-hero-media{opacity:.62} dim */
  #shopify-section-{{ section.id }} .d-hero-media{ opacity: 1; }
  /* Per-slide content position (quadrants + center) */
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide.d-hp--top_left{ align-items: flex-start; justify-content: flex-start; }
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide.d-hp--top_right{ align-items: flex-start; justify-content: flex-end; }
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide.d-hp--bottom_left{ align-items: flex-end; justify-content: flex-start; }
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide.d-hp--bottom_right{ align-items: flex-end; justify-content: flex-end; }
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide.d-hp--center{ align-items: center; justify-content: center; }
  /* Right-aligned positions */
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--top_right .d-hero-content,
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--bottom_right .d-hero-content{ text-align: right; }
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--top_right .d-hero-p,
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--bottom_right .d-hero-p{ margin-left: auto; }
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--top_right .d-hero-btns,
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--bottom_right .d-hero-btns{ justify-content: flex-end; }
  /* Center position */
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--center .d-hero-content{ text-align: center; max-width: 760px; }
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--center .d-hero-p{ margin: 0 auto; }
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--center .d-hero-btns{ justify-content: center; }
  /* Top positions: move the content padding to the top */
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--top_left .d-hero-content,
  #shopify-section-{{ section.id }} .swiper-slide.d-hp--top_right .d-hero-content{ padding-top: 72px; padding-bottom: 0; }
  /* Pagination dots */
  #shopify-section-{{ section.id }} .swiper-pagination{ bottom: 22px; z-index: 6; }
  #shopify-section-{{ section.id }} .swiper-pagination-bullet{
    width: 9px; height: 9px; background: var(--d-beige-lt); opacity: .45;
  }
  #shopify-section-{{ section.id }} .swiper-pagination-bullet-active{ opacity: 1; }
  /* Prev/next arrows */
  #shopify-section-{{ section.id }} .swiper-button-prev,
  #shopify-section-{{ section.id }} .swiper-button-next{
    --swiper-navigation-size: 20px;
    width: 46px; height: 46px; margin-top: 0; top: 50%; transform: translateY(-50%);
    border-radius: 50%; padding: 0; cursor: pointer; z-index: 6;
    color: var(--d-beige-lt);
    background: rgba(17,20,16,.35);
    border: 1px solid rgba(232,224,204,.3);
    transition: background .18s, border-color .18s;
  }
  #shopify-section-{{ section.id }} .swiper-button-prev:hover,
  #shopify-section-{{ section.id }} .swiper-button-next:hover{
    background: rgba(17,20,16,.6); border-color: rgba(232,224,204,.65);
  }
  #shopify-section-{{ section.id }} .swiper-button-prev::after,
  #shopify-section-{{ section.id }} .swiper-button-next::after{ font-weight: 700; }
  #shopify-section-{{ section.id }} .swiper-button-prev{ left: 22px; }
  #shopify-section-{{ section.id }} .swiper-button-next{ right: 22px; }
  @media(max-width: 720px){
    #shopify-section-{{ section.id }} .swiper-button-prev,
    #shopify-section-{{ section.id }} .swiper-button-next{ width: 38px; height: 38px; }
    #shopify-section-{{ section.id }} .swiper-button-prev{ left: 12px; }
    #shopify-section-{{ section.id }} .swiper-button-next{ right: 12px; }
  }
{%- endstyle -%}

<section class="d-hero d-hero--slider">
  <div class="swiper" id="DHeroSwiper-{{ section.id }}">
    <div class="swiper-wrapper">
      {%- for block in section.blocks -%}
        {%- assign ov = block.settings.overlay_opacity | default: 100 -%}
        {%- assign pos = block.settings.content_position | default: 'bottom_left' -%}
        <div class="swiper-slide d-hp--{{ pos }}" {{ block.shopify_attributes }}>
          {%- case block.type -%}

            {%- when 'image_slide' -%}
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 2000 | image_tag:
                  loading: 'eager', widths: '750, 1000, 1500, 2000', sizes: '100vw',
                  class: 'd-hero-media', alt: block.settings.image.alt | default: shop.name }}
              {%- else -%}
                <div class="d-hero-media" style="background:linear-gradient(135deg,#1F3018,#111410);"></div>
              {%- endif -%}
              <div class="d-hero-overlay" style="opacity:{{ ov | divided_by: 100.0 }}"></div>
              <div class="d-hero-content">
                {%- if block.settings.caption != blank -%}
                  <div class="d-hero-kicker"{% if block.settings.text_color != blank %} style="color:{{ block.settings.text_color }}"{% endif %}>{{ block.settings.caption }}</div>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="d-hero-h1"{% if block.settings.text_color != blank %} style="color:{{ block.settings.text_color }}"{% endif %}>{{ block.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h2>
                {%- endif -%}
                {%- if block.settings.subtitle != blank -%}
                  <p class="d-hero-p"{% if block.settings.text_color != blank %} style="color:{{ block.settings.text_color }}"{% endif %}>{{ block.settings.subtitle }}</p>
                {%- endif -%}
                {%- if block.settings.button_label_1 != blank or block.settings.button_label_2 != blank -%}
                  <div class="d-hero-btns">
                    {%- if block.settings.button_label_1 != blank -%}
                      <a href="{{ block.settings.button_link_1 | default: '#' }}" class="d-btn-hp"{% if block.settings.button_bg != blank or block.settings.button_color != blank %} style="{% if block.settings.button_bg != blank %}background:{{ block.settings.button_bg }};{% endif %}{% if block.settings.button_color != blank %}color:{{ block.settings.button_color }};{% endif %}"{% endif %}>{{ block.settings.button_label_1 }}</a>
                    {%- endif -%}
                    {%- if block.settings.button_label_2 != blank -%}
                      <a href="{{ block.settings.button_link_2 | default: '#' }}" class="d-btn-hg"{% if block.settings.button_color_2 != blank %} style="color:{{ block.settings.button_color_2 }};border-color:{{ block.settings.button_color_2 }}"{% endif %}>{{ block.settings.button_label_2 }} →</a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>

            {%- when 'video_slide' -%}
              {%- assign poster_url = block.settings.poster | image_url: width: 1500 -%}
              {%- if block.settings.video != blank -%}
                <video class="d-hero-media" autoplay muted loop playsinline preload="metadata"
                  {% if poster_url != blank %}poster="{{ poster_url }}"{% endif %}>
                  {%- for source in block.settings.video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>
              {%- elsif block.settings.poster != blank -%}
                {{ block.settings.poster | image_url: width: 2000 | image_tag:
                  loading: 'lazy', widths: '750, 1000, 1500, 2000', sizes: '100vw',
                  class: 'd-hero-media', alt: shop.name }}
              {%- else -%}
                <div class="d-hero-media" style="background:linear-gradient(135deg,#1F3018,#111410);"></div>
              {%- endif -%}
              <div class="d-hero-overlay" style="opacity:{{ ov | divided_by: 100.0 }}"></div>
              {%- if block.settings.caption != blank or block.settings.heading != blank or block.settings.subtitle != blank or block.settings.button_label_1 != blank -%}
                <div class="d-hero-content">
                  {%- if block.settings.caption != blank -%}
                    <div class="d-hero-kicker"{% if block.settings.text_color != blank %} style="color:{{ block.settings.text_color }}"{% endif %}>{{ block.settings.caption }}</div>
                  {%- endif -%}
                  {%- if block.settings.heading != blank -%}
                    <h2 class="d-hero-h1"{% if block.settings.text_color != blank %} style="color:{{ block.settings.text_color }}"{% endif %}>{{ block.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h2>
                  {%- endif -%}
                  {%- if block.settings.subtitle != blank -%}
                    <p class="d-hero-p"{% if block.settings.text_color != blank %} style="color:{{ block.settings.text_color }}"{% endif %}>{{ block.settings.subtitle }}</p>
                  {%- endif -%}
                  {%- if block.settings.button_label_1 != blank -%}
                    <div class="d-hero-btns">
                      <a href="{{ block.settings.button_link_1 | default: '#' }}" class="d-btn-hp"{% if block.settings.button_bg != blank or block.settings.button_color != blank %} style="{% if block.settings.button_bg != blank %}background:{{ block.settings.button_bg }};{% endif %}{% if block.settings.button_color != blank %}color:{{ block.settings.button_color }};{% endif %}"{% endif %}>{{ block.settings.button_label_1 }}</a>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
    <div class="swiper-pagination"></div>
    <button type="button" class="swiper-button-prev d-hero-nav" aria-label="Previous slide"></button>
    <button type="button" class="swiper-button-next d-hero-nav" aria-label="Next slide"></button>
  </div>
</section>

<script>
  (function(){
    var sel = '#DHeroSwiper-{{ section.id }}';
    function init(){
      var el = document.querySelector(sel);
      if (!el || el.dataset.inited) return;
      if (typeof Swiper === 'undefined') { return window.setTimeout(init, 60); }
      el.dataset.inited = '1';
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      new Swiper(el, {
        loop: true,
        speed: 800,
        autoplay: reduce ? false : { delay: 6000, disableOnInteraction: false },
        pagination: { el: el.querySelector('.swiper-pagination'), clickable: true },
        navigation: {
          prevEl: el.querySelector('.swiper-button-prev'),
          nextEl: el.querySelector('.swiper-button-next')
        }
      });
    }
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
  })();
</script>

{% schema %}
{
  "name": "Divine Hero",
  "tag": "section",
  "class": "divine-hero-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "range",
      "id": "image_height",
      "label": "Hero height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 95,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Image slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption (above heading)" },
        { "type": "html", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
        { "type": "text", "id": "button_label_1", "label": "Primary button label" },
        { "type": "url", "id": "button_link_1", "label": "Primary button link" },
        { "type": "text", "id": "button_label_2", "label": "Secondary button label" },
        { "type": "url", "id": "button_link_2", "label": "Secondary button link" },
        { "type": "color", "id": "button_bg", "label": "Primary button background" },
        { "type": "color", "id": "button_color", "label": "Primary button text color" },
        { "type": "color", "id": "button_color_2", "label": "Secondary button color" },
        { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "default": 100, "unit": "%" },
        { "type": "select", "id": "content_position", "label": "Content position", "options": [ { "value": "top_left", "label": "Top left" }, { "value": "top_right", "label": "Top right" }, { "value": "bottom_left", "label": "Bottom left" }, { "value": "bottom_right", "label": "Bottom right" }, { "value": "center", "label": "Center" } ], "default": "bottom_left" },
        { "type": "color", "id": "text_color", "label": "Text color", "default": "#E8E0CC" }
      ]
    },
    {
      "type": "video_slide",
      "name": "Video slide",
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "poster", "label": "Poster / fallback image" },
        { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "default": 100, "unit": "%" },
        { "type": "text", "id": "caption", "label": "Caption (above heading)" },
        { "type": "html", "id": "heading", "label": "Heading (optional)" },
        { "type": "textarea", "id": "subtitle", "label": "Subtitle (optional)" },
        { "type": "text", "id": "button_label_1", "label": "Button label (optional)" },
        { "type": "url", "id": "button_link_1", "label": "Button link (optional)" },
        { "type": "color", "id": "button_bg", "label": "Button background" },
        { "type": "color", "id": "button_color", "label": "Button text color" },
        { "type": "select", "id": "content_position", "label": "Content position", "options": [ { "value": "top_left", "label": "Top left" }, { "value": "top_right", "label": "Top right" }, { "value": "bottom_left", "label": "Bottom left" }, { "value": "bottom_right", "label": "Bottom right" }, { "value": "center", "label": "Center" } ], "default": "bottom_left" },
        { "type": "color", "id": "text_color", "label": "Text color", "default": "#E8E0CC" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Hero",
      "blocks": [
        { "type": "image_slide" },
        { "type": "image_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
