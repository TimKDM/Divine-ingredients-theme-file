{{ 'swiper.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper.min.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  #shopify-section-{{ section.id }} .d-hero{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    {% if section.settings.image_height != blank and section.settings.image_height != 0 %}
      height: {{ section.settings.image_height }}vh;
    {% endif %}
  }
  /* Slider: each slide replicates the hero frame (full-bleed media + bottom copy) */
  #shopify-section-{{ section.id }} .d-hero--slider{ display: block; }
  #shopify-section-{{ section.id }} .d-hero--slider .swiper,
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-wrapper,
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide{ height: 100%; width: 100%; }
  #shopify-section-{{ section.id }} .d-hero--slider .swiper-slide{
    position: relative; display: flex; align-items: flex-end;
    overflow: hidden; background: var(--d-black);
  }
  #shopify-section-{{ section.id }} .d-hero-content--center{
    margin: 0 auto; text-align: center; max-width: 760px;
  }
  #shopify-section-{{ section.id }} .d-hero-content--center .d-hero-p{ margin-left: auto; margin-right: auto; }
  #shopify-section-{{ section.id }} .d-hero-content--center .d-hero-btns{ justify-content: center; }
  /* Pagination dots */
  #shopify-section-{{ section.id }} .swiper-pagination{ bottom: 22px; z-index: 6; }
  #shopify-section-{{ section.id }} .swiper-pagination-bullet{
    width: 9px; height: 9px; background: var(--d-beige-lt); opacity: .45;
  }
  #shopify-section-{{ section.id }} .swiper-pagination-bullet-active{ opacity: 1; }

  /* "Ready to discover?" prompt chip (fades in after a delay, click to open the Chai Edit modal) */
  #shopify-section-{{ section.id }} .d-hero-prompt{
    position: absolute; bottom: 28px; right: 28px; z-index: 12;
    display: flex; align-items: center; gap: 8px;
    opacity: 0; visibility: hidden; transform: translateY(10px); pointer-events: none;
    transition: opacity .45s ease, transform .45s ease, visibility .45s;
  }
  #shopify-section-{{ section.id }} .d-hero-prompt.is-visible{
    opacity: 1; visibility: visible; transform: none; pointer-events: auto;
  }
  #shopify-section-{{ section.id }} .d-hero-prompt__btn{
    background: var(--d-beige-lt); color: var(--d-black); border: none;
    border-radius: 100px; padding: 13px 24px; cursor: pointer;
    font-family: var(--d-font-sans); font-size: 13px; font-weight: 500; letter-spacing: .04em;
    box-shadow: 0 8px 28px rgba(0,0,0,.28); transition: transform .12s;
  }
  #shopify-section-{{ section.id }} .d-hero-prompt__btn:hover{ transform: translateY(-1px); }
  #shopify-section-{{ section.id }} .d-hero-prompt__dismiss{
    background: rgba(17,20,16,.5); color: #fff; border: none; border-radius: 50%;
    width: 26px; height: 26px; font-size: 16px; line-height: 1; cursor: pointer; padding: 0;
  }
  @media(max-width: 720px){
    #shopify-section-{{ section.id }} .d-hero-prompt{ bottom: 18px; right: 18px; }
  }
{%- endstyle -%}

<section class="d-hero d-hero--slider">
  <div class="swiper" id="DHeroSwiper-{{ section.id }}">
    <div class="swiper-wrapper">
      {%- for block in section.blocks -%}
        {%- assign ov = block.settings.overlay_opacity | default: 100 -%}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          {%- case block.type -%}

            {%- when 'image_slide' -%}
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 2000 | image_tag:
                  loading: 'eager', widths: '750, 1000, 1500, 2000', sizes: '100vw',
                  class: 'd-hero-media', alt: block.settings.image.alt | default: shop.name }}
              {%- else -%}
                <div class="d-hero-media" style="background:linear-gradient(135deg,#1F3018,#111410);"></div>
              {%- endif -%}
              <div class="d-hero-overlay" style="opacity:{{ ov | divided_by: 100.0 }}"></div>
              <div class="d-hero-content{% if block.settings.text_position == 'center' %} d-hero-content--center{% endif %}">
                {%- if block.settings.heading != blank -%}
                  <h2 class="d-hero-h1">{{ block.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h2>
                {%- endif -%}
                {%- if block.settings.subtitle != blank -%}
                  <p class="d-hero-p">{{ block.settings.subtitle }}</p>
                {%- endif -%}
                {%- if block.settings.button_label_1 != blank or block.settings.button_label_2 != blank -%}
                  <div class="d-hero-btns">
                    {%- if block.settings.button_label_1 != blank -%}
                      <a href="{{ block.settings.button_link_1 | default: '#' }}" class="d-btn-hp">{{ block.settings.button_label_1 }}</a>
                    {%- endif -%}
                    {%- if block.settings.button_label_2 != blank -%}
                      <a href="{{ block.settings.button_link_2 | default: '#' }}" class="d-btn-hg">{{ block.settings.button_label_2 }} →</a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>

            {%- when 'video_slide' -%}
              {%- assign poster_url = block.settings.poster | image_url: width: 1500 -%}
              {%- if block.settings.video != blank -%}
                <video class="d-hero-media" autoplay muted loop playsinline preload="metadata"
                  {% if poster_url != blank %}poster="{{ poster_url }}"{% endif %}>
                  {%- for source in block.settings.video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>
              {%- elsif block.settings.poster != blank -%}
                {{ block.settings.poster | image_url: width: 2000 | image_tag:
                  loading: 'lazy', widths: '750, 1000, 1500, 2000', sizes: '100vw',
                  class: 'd-hero-media', alt: shop.name }}
              {%- else -%}
                <div class="d-hero-media" style="background:linear-gradient(135deg,#1F3018,#111410);"></div>
              {%- endif -%}
              <div class="d-hero-overlay" style="opacity:{{ ov | divided_by: 100.0 }}"></div>
              {%- if block.settings.heading != blank or block.settings.subtitle != blank or block.settings.button_label_1 != blank -%}
                <div class="d-hero-content">
                  {%- if block.settings.heading != blank -%}
                    <h2 class="d-hero-h1">{{ block.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h2>
                  {%- endif -%}
                  {%- if block.settings.subtitle != blank -%}
                    <p class="d-hero-p">{{ block.settings.subtitle }}</p>
                  {%- endif -%}
                  {%- if block.settings.button_label_1 != blank -%}
                    <div class="d-hero-btns">
                      <a href="{{ block.settings.button_link_1 | default: '#' }}" class="d-btn-hp">{{ block.settings.button_label_1 }}</a>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
    <div class="swiper-pagination"></div>
  </div>

  {%- if section.settings.enable_chai_prompt -%}
    <div class="d-hero-prompt" data-prompt-delay="{{ section.settings.prompt_delay | default: 5 }}">
      <button type="button" class="d-hero-prompt__btn" data-open-chai-popup>{{ section.settings.prompt_label | default: 'Ready to discover?' }}</button>
      <button type="button" class="d-hero-prompt__dismiss" aria-label="Dismiss">&times;</button>
    </div>
    {% render 'chai-edit-popup' %}
  {%- endif -%}
</section>

<script>
  (function(){
    var sel = '#DHeroSwiper-{{ section.id }}';
    function init(){
      var el = document.querySelector(sel);
      if (!el || el.dataset.inited) return;
      if (typeof Swiper === 'undefined') { return window.setTimeout(init, 60); }
      el.dataset.inited = '1';
      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      new Swiper(el, {
        loop: true,
        speed: 800,
        autoplay: reduce ? false : { delay: 6000, disableOnInteraction: false },
        pagination: { el: el.querySelector('.swiper-pagination'), clickable: true }
      });
    }
    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
  })();
</script>

{%- if section.settings.enable_chai_prompt -%}
<script>
  (function(){
    var prompt = document.querySelector('#shopify-section-{{ section.id }} .d-hero-prompt');
    if (!prompt || prompt.dataset.bound) return;
    prompt.dataset.bound = '1';
    var KEY = 'dChaiPromptSeen';
    try { if (sessionStorage.getItem(KEY)) return; } catch (e) {}

    var delay = (parseFloat(prompt.getAttribute('data-prompt-delay')) || 5) * 1000;
    var dismissBtn = prompt.querySelector('.d-hero-prompt__dismiss');
    var openBtn = prompt.querySelector('.d-hero-prompt__btn');
    var hero = prompt.closest('.d-hero') || prompt;
    var shown = false, timer = null;

    function reveal(){ if (!shown) { shown = true; prompt.classList.add('is-visible'); } }
    function markSeen(){ try { sessionStorage.setItem(KEY, '1'); } catch (e) {} }
    function hide(){ prompt.classList.remove('is-visible'); }

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(en){
          if (en.isIntersecting && !timer && !shown) { timer = setTimeout(reveal, delay); }
        });
      }, { threshold: 0.25 });
      io.observe(hero);
    } else {
      timer = setTimeout(reveal, delay);
    }

    if (dismissBtn) dismissBtn.addEventListener('click', function(){ hide(); markSeen(); });
    if (openBtn) openBtn.addEventListener('click', function(){ hide(); markSeen(); });
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Divine Hero",
  "tag": "section",
  "class": "divine-hero-section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "range",
      "id": "image_height",
      "label": "Hero height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "default": 95,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Chai Edit prompt"
    },
    {
      "type": "checkbox",
      "id": "enable_chai_prompt",
      "label": "Show \"Ready to discover?\" prompt",
      "info": "Fades in over the hero after a delay; opens the Chai Edit pop-up on click.",
      "default": true
    },
    {
      "type": "text",
      "id": "prompt_label",
      "label": "Prompt label",
      "default": "Ready to discover?"
    },
    {
      "type": "range",
      "id": "prompt_delay",
      "label": "Prompt delay",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 5,
      "unit": "s"
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Image slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "html", "id": "heading", "label": "Heading" },
        { "type": "textarea", "id": "subtitle", "label": "Subtitle" },
        { "type": "text", "id": "button_label_1", "label": "Primary button label" },
        { "type": "url", "id": "button_link_1", "label": "Primary button link" },
        { "type": "text", "id": "button_label_2", "label": "Secondary button label" },
        { "type": "url", "id": "button_link_2", "label": "Secondary button link" },
        { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "default": 100, "unit": "%" },
        { "type": "select", "id": "text_position", "label": "Text position", "options": [ { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" } ], "default": "left" }
      ]
    },
    {
      "type": "video_slide",
      "name": "Video slide",
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "poster", "label": "Poster / fallback image" },
        { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "default": 100, "unit": "%" },
        { "type": "html", "id": "heading", "label": "Heading (optional)" },
        { "type": "textarea", "id": "subtitle", "label": "Subtitle (optional)" },
        { "type": "text", "id": "button_label_1", "label": "Button label (optional)" },
        { "type": "url", "id": "button_link_1", "label": "Button link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Hero",
      "blocks": [
        { "type": "image_slide" },
        { "type": "image_slide" },
        { "type": "video_slide" }
      ]
    }
  ]
}
{% endschema %}
