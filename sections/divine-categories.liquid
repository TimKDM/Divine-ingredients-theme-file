{{ 'divine-mockup-v3.css' | asset_url | stylesheet_tag }}

<section class="divine-section">
  <div class="divine-section-header">
    {%- if section.settings.caption != blank -%}
      <span class="divine-section-label">{{ section.settings.caption }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="divine-section-title">{{ section.settings.title }}</h2>
    {%- endif -%}
  </div>

  <div class="divine-category-grid">
    {%- for block in section.blocks -%}
      {%- assign collection = collections[block.settings.collection] -%}
      <a href="{{ collection.url | default: '#' }}" class="divine-category-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              widths: '200, 300, 400, 600',
              sizes: '(min-width: 768px) 25vw, 50vw'
          }}
        {%- elsif collection.image != blank -%}
          {{
            collection.image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              widths: '200, 300, 400, 600',
              sizes: '(min-width: 768px) 25vw, 50vw'
          }}
        {%- elsif collection.products.first.featured_image != blank -%}
          {{
            collection.products.first.featured_image
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              widths: '200, 300, 400, 600',
              sizes: '(min-width: 768px) 25vw, 50vw'
          }}
        {%- else -%}
          {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="divine-category-card__content">
          <h3>{{ block.settings.heading | default: collection.title }}</h3>
          {%- if block.settings.subtitle != blank -%}
            <p>{{ block.settings.subtitle }}</p>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Categories",
  "tag": "section",
  "class": "divine-categories-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Explore Our Collections"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image (optional)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Custom heading (optional)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Explore"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Categories",
      "blocks": [
        { "type": "category", "settings": { "heading": "Matcha", "subtitle": "Ceremonial & culinary" } },
        { "type": "category", "settings": { "heading": "Loose Leaf Tea", "subtitle": "Black, green & herbal" } },
        { "type": "category", "settings": { "heading": "Superfoods", "subtitle": "Adaptogens & blends" } },
        { "type": "category", "settings": { "heading": "Artisan Spices", "subtitle": "Single origin & blends" } }
      ]
    }
  ]
}
{% endschema %}
