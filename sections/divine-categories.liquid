{%- style -%}
  #shopify-section-{{ section.id }} .d-ritual{
    {% if section.settings.background_color != blank %}background-color: {{ section.settings.background_color }};{% endif %}
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    padding-top: {{ section.settings.padding_top | default: 96 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 96 }}px;
  }
  #shopify-section-{{ section.id }} .d-rc-teas{
    font-size: {{ section.settings.body_font_size | default: 12 }}px;
  }
  #shopify-section-{{ section.id }} .d-sec-h{
    font-size: {{ section.settings.heading_font_size | default: 52 }}px;
  }
  #shopify-section-{{ section.id }} .d-rc-title{
    font-size: {{ section.settings.item_heading_font_size | default: 22 }}px;
  }
  #shopify-section-{{ section.id }} .d-sec-label{
    font-size: {{ section.settings.caption_font_size | default: 11 }}px;
    {% if section.settings.accent_color != blank %}color: {{ section.settings.accent_color }};{% endif %}
  }
  {% if section.settings.text_color != blank %}
  #shopify-section-{{ section.id }} .d-sec-h,
  #shopify-section-{{ section.id }} .d-rc-title{
    color: {{ section.settings.text_color }};
  }
  {% endif %}
  #shopify-section-{{ section.id }} .d-ritual-grid{
    grid-template-columns: repeat({{ section.blocks.size | at_least: 1 | at_most: 5 }}, 1fr);
  }
  @media (max-width: 1100px){
    #shopify-section-{{ section.id }} .d-ritual-grid{ grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 720px){
    #shopify-section-{{ section.id }} .d-ritual-grid{ grid-template-columns: 1fr; }
  }
{%- endstyle -%}

<section class="d-ritual d-reveal">
  <div class="d-ritual-header">
    <div>
      {%- if section.settings.caption != blank -%}
        <div class="d-sec-label">{{ section.settings.caption }}</div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="d-sec-h">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="d-sec-p" style="max-width:420px;margin-top:12px;">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '/collections' }}" class="d-btn-t" style="flex-shrink:0;margin-bottom:8px">{{ section.settings.cta_label }} →</a>
    {%- endif -%}
  </div>

  <div class="d-ritual-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign collection = block.settings.collection
        if block.settings.link != blank
          assign card_url = block.settings.link
        elsif collection != blank
          assign card_url = collection.url
        else
          assign card_url = '#'
        endif
        if block.settings.image != blank
          assign card_image = block.settings.image
        elsif collection.image != blank
          assign card_image = collection.image
        elsif collection.products.first.featured_image != blank
          assign card_image = collection.products.first.featured_image
        else
          assign card_image = blank
        endif
      -%}
      <a href="{{ card_url }}" class="d-rc" {{ block.shopify_attributes }}>
        {%- if card_image != blank -%}
          {{ card_image | image_url: width: 800 | image_tag:
            loading: 'lazy',
            widths: '300, 500, 700, 900',
            sizes: '(min-width: 1100px) 20vw, 50vw',
            class: 'd-rc-img',
            alt: card_image.alt | default: block.settings.heading | default: ''
          }}
        {%- else -%}
          <div class="d-rc-img" style="background:linear-gradient(135deg,#0e1208,#1F3018);"></div>
        {%- endif -%}
        <div class="d-rc-grad"></div>
        <div class="d-rc-content">
          {%- if block.settings.tag != blank -%}
            <div class="d-rc-tag">{{ block.settings.tag }}</div>
          {%- endif -%}
          {%- if block.settings.heading != blank or collection.title != blank -%}
            <div class="d-rc-title">{{ block.settings.heading | default: collection.title }}</div>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <div class="d-rc-desc">{{ block.settings.description }}</div>
          {%- endif -%}
          {%- if block.settings.subtitle != blank -%}
            <div class="d-rc-teas">{{ block.settings.subtitle }}</div>
          {%- endif -%}
          {%- if block.settings.cta != blank -%}
            <div class="d-rc-cta">{{ block.settings.cta }} →</div>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Categories",
  "tag": "section",
  "class": "divine-categories-section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Shop Teas"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Find your perfect cup"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "36 teas — browse by mood or moment. Find what fits your day."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Header CTA label",
      "default": "Browse all teas"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Header CTA link"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 10,
      "max": 22,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 80,
      "step": 1,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Caption font size",
      "min": 8,
      "max": 18,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "item_heading_font_size",
      "label": "Card title font size",
      "min": 12,
      "max": 36,
      "step": 1,
      "default": 22,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Ritual card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Top tag",
          "default": "Morning"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Card title",
          "default": "Morning Ritual"
        },
        {
          "type": "text",
          "id": "description",
          "label": "One-line description"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Featured items / tea list"
        },
        {
          "type": "text",
          "id": "cta",
          "label": "CTA label",
          "default": "Shop Morning"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Categories",
      "settings": { "caption": "Shop by Function", "title": "Your cup, your ritual.", "subtitle": "Find what fits your day." },
      "blocks": [
        { "type": "category", "settings": { "heading": "Immunity", "description": "Antioxidant-rich blends for daily defence and seasonal support.", "subtitle": "Turmeric Wellness · Ginger Lemon · Elderberry Boost · Tulsi Holy Basil · Echinacea Defence", "cta": "Shop Immunity" } },
        { "type": "category", "settings": { "heading": "Wind Down", "description": "Calming botanicals and herbal blends for restful evenings.", "subtitle": "Chamomile Care · Serenity · Relax Hemp · Lavender Calm · Lemon Balm", "cta": "Shop Wind Down" } },
        { "type": "category", "settings": { "heading": "Gut Reset", "description": "Digestive teas and after-meal botanicals to settle the system.", "subtitle": "Peppermint · Fennel Digestive · Ginger Turmeric · Licorice Root · Triphala Blend", "cta": "Shop Gut Reset" } },
        { "type": "category", "settings": { "heading": "Focus & Energy", "description": "Bright greens, matcha, and adaptogens for steady, focused energy.", "subtitle": "Ceremonial Matcha · Sencha · Genmaicha · Yerba Mate · Energize Hemp", "cta": "Shop Focus" } },
        { "type": "category", "settings": { "heading": "Detox", "description": "Cleansing herbs and bitter botanicals for gentle detoxification.", "subtitle": "Dandelion Root · Milk Thistle · Nettle Cleanse · Burdock · Detox Greens", "cta": "Shop Detox" } }
      ]
    }
  ]
}
{% endschema %}
