{%- comment -%}
  Divine Footer. Dark footer matching the mockup
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .d-footer{
    {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}background:{{ section.settings.background_color }};{% endif %}
    padding-top: {{ section.settings.padding_top | default: 72 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 36 }}px;
  }
{%- endstyle -%}

<footer class="d-footer">
  <div class="d-ft">

    {%- comment -%} Brand block {%- endcomment -%}
    <div>
      <div class="d-f-logo">
        {%- if section.settings.logo_text != blank -%}
          {%- assign parts = section.settings.logo_text | split: '*' -%}
          {%- for p in parts -%}
            {%- assign p_mod = forloop.index0 | modulo: 2 -%}
            {%- if p_mod == 1 -%}<em>{{ p }}</em>{%- else -%}{{ p }}{%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </div>
      {%- if section.settings.description != blank -%}
        <div class="d-f-desc">{{ section.settings.description }}</div>
      {%- endif -%}
      <div class="d-f-socials">
        {%- if section.settings.instagram != blank -%}
          <a href="{{ section.settings.instagram }}" class="d-fsoc" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.tiktok != blank -%}
          <a href="{{ section.settings.tiktok }}" class="d-fsoc" aria-label="TikTok" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M16.5 5.5a4.5 4.5 0 0 0 4 4v3a7.5 7.5 0 0 1-4-1.2v6.2a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v3.1a2.5 2.5 0 1 0 1.6 2.3V3h3v2.5z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.pinterest != blank -%}
          <a href="{{ section.settings.pinterest }}" class="d-fsoc" aria-label="Pinterest" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2a10 10 0 0 0-3.6 19.3c-.1-.8-.2-2 0-2.9l1.3-5.4s-.3-.7-.3-1.7c0-1.6.9-2.8 2.1-2.8 1 0 1.5.7 1.5 1.6 0 1-.6 2.5-1 3.9-.3 1.2.6 2.1 1.7 2.1 2.1 0 3.6-2.2 3.6-5.3 0-2.8-2-4.7-4.9-4.7-3.3 0-5.3 2.5-5.3 5.1 0 1 .4 2.1 1 2.7l.1.4-.4 1.6c-.1.3-.2.3-.4.2-1.4-.7-2.3-2.7-2.3-4.4 0-3.6 2.6-6.8 7.5-6.8 3.9 0 7 2.8 7 6.5 0 3.9-2.5 7.1-5.9 7.1-1.2 0-2.2-.6-2.6-1.4l-.7 2.7c-.3 1-.9 2.2-1.4 3A10 10 0 1 0 12 2z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook != blank -%}
          <a href="{{ section.settings.facebook }}" class="d-fsoc" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9V14.9H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.5 2.9h-2.3v7A10 10 0 0 0 22 12z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.youtube != blank -%}
          <a href="{{ section.settings.youtube }}" class="d-fsoc" aria-label="YouTube" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M21.6 7.2s-.2-1.4-.8-2c-.7-.8-1.6-.8-2-.9C16 4 12 4 12 4s-4 0-6.8.3c-.4.1-1.3.1-2 .9-.6.6-.8 2-.8 2S2 8.8 2 10.5v1.6c0 1.6.2 3.3.2 3.3s.2 1.4.8 2c.7.8 1.7.8 2.2.9 1.6.1 6.8.3 6.8.3s4 0 6.8-.3c.4-.1 1.3-.1 2-.9.6-.6.8-2 .8-2s.2-1.6.2-3.3v-1.6c0-1.6-.2-3.3-.2-3.3zM9.8 13.9V8.1l5.2 2.9-5.2 2.9z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.linkedin != blank -%}
          <a href="{{ section.settings.linkedin }}" class="d-fsoc" aria-label="LinkedIn" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zM8.3 18H5.7V9.7h2.6V18zM7 8.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm11.3 9.5h-2.6v-4c0-1-.4-1.6-1.3-1.6-.7 0-1.1.5-1.3 1-.1.2-.1.4-.1.6V18h-2.6V9.7h2.6v1.1c.3-.5 1-1.3 2.4-1.3 1.7 0 3 1.1 3 3.5V18z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.x_twitter != blank -%}
          <a href="{{ section.settings.x_twitter }}" class="d-fsoc" aria-label="X (Twitter)" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Menu columns from blocks {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu_column' -%}
        <div {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <div class="d-f-col-h">{{ block.settings.heading }}</div>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul class="d-fl">
              {%- for link in block.settings.menu.links -%}
                {%- assign is_special = false -%}
                {%- if link.title contains '→' -%}{%- assign is_special = true -%}{%- endif -%}
                <li><a href="{{ link.url }}"{% if is_special %} class="d-sp"{% endif %}>{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
          {%- if block.settings.heading_2 != blank -%}
            <div class="d-f-col-h" style="margin-top:24px">{{ block.settings.heading_2 }}</div>
          {%- endif -%}
          {%- if block.settings.menu_2 != blank -%}
            <ul class="d-fl">
              {%- for link in block.settings.menu_2.links -%}
                {%- assign is_special = false -%}
                {%- if link.title contains '→' -%}{%- assign is_special = true -%}{%- endif -%}
                <li><a href="{{ link.url }}"{% if is_special %} class="d-sp"{% endif %}>{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="d-fb">
    <div class="d-fb-legal">
      © {{ 'now' | date: '%Y' }}, {{ shop.name }}.
      {%- if section.settings.privacy_link != blank -%}<a href="{{ section.settings.privacy_link }}">Privacy</a>{%- endif -%}
      {%- if section.settings.terms_link != blank -%}<a href="{{ section.settings.terms_link }}">Terms</a>{%- endif -%}
      {%- if section.settings.contact_link != blank -%}<a href="{{ section.settings.contact_link }}">Contact</a>{%- endif -%}
    </div>
    <div class="d-fb-meta">{{ section.settings.locale_text }}</div>
  </div>
</footer>

{% schema %}
{
  "name": "Divine Footer",
  "tag": "section",
  "class": "divine-footer-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (use * for italics)",
      "default": "Divine *Ingredients*"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "Farm-sourced teas, superfoods, and botanicals. Every batch tested, every ingredient real."
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "linkedin",
      "label": "LinkedIn URL"
    },
    {
      "type": "url",
      "id": "x_twitter",
      "label": "X (Twitter) URL"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "url",
      "id": "privacy_link",
      "label": "Privacy link"
    },
    {
      "type": "url",
      "id": "terms_link",
      "label": "Terms link"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact link"
    },
    {
      "type": "text",
      "id": "locale_text",
      "label": "Locale text",
      "default": "CA ($) · US ($)"
    },
    {
      "type": "header",
      "content": "Colors & spacing"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 24,
      "max": 160,
      "step": 4,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 12,
      "max": 100,
      "step": 4,
      "default": 36,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" },
        { "type": "header", "content": "Optional second list" },
        { "type": "text", "id": "heading_2", "label": "Second heading" },
        { "type": "link_list", "id": "menu_2", "label": "Second menu" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "heading": "Shop Teas" } },
        { "type": "menu_column", "settings": { "heading": "Shop Powders" } },
        { "type": "menu_column", "settings": { "heading": "Help" } }
      ]
    }
  ]
}
{% endschema %}
