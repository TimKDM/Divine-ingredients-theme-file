{%- comment -%}
  Divine Story Page — About-Us layout
  Mirrors the About-Us mockup: breadcrumb, page hero with founder photo,
  pull quote, story body w/ sidebar cards, 3-col values, 4-col certs grid, CTA band.

  Uses block types to keep backwards compatibility with existing JSON:
    - intro      → page hero (heading + intro)
    - image_text → reused as: pull_quote or story body (depending on caption tag)
    - cta        → forest-green CTA band
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .divine-story-page{
    {% if section.settings.background_color != blank %}background:{{ section.settings.background_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .d-ph-h1{
    font-size: {{ section.settings.heading_font_size | default: 88 }}px;
  }
{%- endstyle -%}

<div class="divine-story-page">

  <div class="d-breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="d-breadcrumb-sep">·</span>
    <span>{{ page.title | default: 'Our Story' }}</span>
  </div>

  {%- for block in section.blocks -%}
    {%- case block.type -%}

      {%- when 'intro' -%}
        <section class="d-page-hero">
          <div class="d-ph-left d-reveal">
            {%- if block.settings.kicker != blank -%}
              <div class="d-ph-kicker">{{ block.settings.kicker }}</div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h1 class="d-ph-h1">{{ block.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h1>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="d-ph-intro">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
          <div class="d-ph-right">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag:
                loading: 'eager', widths: '500, 750, 1000, 1200',
                sizes: '(min-width: 1100px) 50vw, 100vw',
                class: 'd-ph-img', alt: block.settings.image.alt | default: 'Founder photo'
              }}
            {%- else -%}
              <div class="d-ph-placeholder">
                <div class="d-ph-placeholder-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(60,76,48,.3)" stroke-width="1.4">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                  </svg>
                </div>
                <div class="d-ph-placeholder-text">{{ block.settings.placeholder_text | default: "Founder photo coming soon" }}</div>
              </div>
            {%- endif -%}
            {%- if block.settings.cap_name != blank -%}
              <div class="d-ph-cap">
                <div class="d-ph-cap-name"><em>{{ block.settings.cap_name }}</em></div>
                {%- if block.settings.cap_role != blank -%}
                  <div class="d-ph-cap-role">{{ block.settings.cap_role }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </section>

      {%- when 'pull_quote' -%}
        <section class="d-pullquote d-reveal">
          <div class="d-pq-line"></div>
          <div>
            <div class="d-pq-text">{{ block.settings.quote | replace: '<p>', '' | replace: '</p>', '' }}</div>
            {%- if block.settings.attribution != blank -%}
              <div class="d-pq-attr">— {{ block.settings.attribution }}</div>
            {%- endif -%}
          </div>
        </section>

      {%- when 'story_body' -%}
        <section class="d-story-section">
          <div class="d-story-body-text d-reveal">
            {{ block.settings.text }}
          </div>
          <div class="d-story-sidebar d-reveal">
            {%- if block.settings.card_1_label != blank or block.settings.card_1_value != blank -%}
              <div class="d-sidebar-card">
                <div class="d-sc-label">{{ block.settings.card_1_label }}</div>
                <div class="d-sc-val">{{ block.settings.card_1_value | replace: "<p>", "" | replace: "</p>", "" }}</div>
                {%- if block.settings.card_1_desc != blank -%}
                  <div class="d-sc-desc">{{ block.settings.card_1_desc }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.card_2_label != blank or block.settings.card_2_value != blank -%}
              <div class="d-sidebar-card">
                <div class="d-sc-label">{{ block.settings.card_2_label }}</div>
                <div class="d-sc-val">{{ block.settings.card_2_value | replace: "<p>", "" | replace: "</p>", "" }}</div>
                {%- if block.settings.card_2_desc != blank -%}
                  <div class="d-sc-desc">{{ block.settings.card_2_desc }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if block.settings.card_3_label != blank or block.settings.card_3_value != blank -%}
              <div class="d-sidebar-card">
                <div class="d-sc-label">{{ block.settings.card_3_label }}</div>
                <div class="d-sc-val">{{ block.settings.card_3_value | replace: "<p>", "" | replace: "</p>", "" }}</div>
                {%- if block.settings.card_3_desc != blank -%}
                  <div class="d-sc-desc">{{ block.settings.card_3_desc }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </section>

      {%- when 'values' -%}
        <section class="d-values d-reveal">
          <div class="d-values-header">
            {%- if block.settings.kicker != blank -%}
              <div class="d-sec-label">{{ block.settings.kicker }}</div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="d-sec-h">{{ block.settings.heading | replace: "<p>", "" | replace: "</p>", "" }}</h2>
            {%- endif -%}
          </div>
          <div class="d-values-grid">
            {%- for i in (1..3) -%}
              {%- assign t_key = 'value_' | append: i | append: '_title' -%}
              {%- assign b_key = 'value_' | append: i | append: '_body' -%}
              {%- assign v_title = block.settings[t_key] -%}
              {%- assign v_body = block.settings[b_key] -%}
              {%- if v_title != blank or v_body != blank -%}
                <div class="d-value-card">
                  <div class="d-vc-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
                  <h3 class="d-vc-title">{{ v_title | replace: "<p>", "" | replace: "</p>", "" }}</h3>
                  <div class="d-vc-body">{{ v_body }}</div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </section>

      {%- when 'certs_grid' -%}
        <section class="d-certs-grid-sec d-reveal">
          <div class="d-certs-header">
            {%- if block.settings.kicker != blank -%}
              <div class="d-sec-label">{{ block.settings.kicker }}</div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="d-sec-h" style="font-size:clamp(32px,3.4vw,46px)">{{ block.settings.heading | replace: "<p>", "" | replace: "</p>", "" }}</h2>
            {%- endif -%}
          </div>
          <div class="d-certs-grid">
            {%- for i in (1..4) -%}
              {%- assign t_key = 'cert_' | append: i | append: '_title' -%}
              {%- assign b_key = 'cert_' | append: i | append: '_body' -%}
              {%- assign c_title = block.settings[t_key] -%}
              {%- assign c_body = block.settings[b_key] -%}
              {%- if c_title != blank or c_body != blank -%}
                <div class="d-cert-card">
                  <div class="d-cert-card-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--d-forest)" stroke-width="1.6">
                      <path d="M9 11l3 3L22 4"/>
                      <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
                    </svg>
                  </div>
                  <div class="d-cert-card-name">{{ c_title }}</div>
                  <div class="d-cert-card-desc">{{ c_body }}</div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </section>

      {%- when 'cta' -%}
        <section class="d-cta-band d-reveal">
          <div>
            {%- if block.settings.kicker != blank -%}
              <div class="d-cta-label">{{ block.settings.kicker }}</div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="d-cta-h">{{ block.settings.heading | replace: "<p>", "" | replace: "</p>", "" }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="d-cta-p">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
          <div class="d-cta-buttons">
            {%- if block.settings.button_label_1 != blank -%}
              <a href="{{ block.settings.button_link_1 | default: '/collections/all' }}" class="d-btn-hp">{{ block.settings.button_label_1 }}</a>
            {%- endif -%}
            {%- if block.settings.button_label_2 != blank -%}
              <a href="{{ block.settings.button_link_2 | default: '#' }}" class="d-btn-t-lt">{{ block.settings.button_label_2 }} →</a>
            {%- endif -%}
            {%- if block.settings.button_label_3 != blank -%}
              <a href="{{ block.settings.button_link_3 | default: '#' }}" class="d-btn-t-lt">{{ block.settings.button_label_3 }} →</a>
            {%- endif -%}
          </div>
        </section>

      {%- when 'image_text' -%}
        {%- comment -%} Legacy block — render as a story section split {%- endcomment -%}
        <section class="d-story{% if block.settings.layout == 'image_left' %} d-story-rev{% endif %}" style="{% if block.settings.use_alt_bg %}background:var(--d-beige-lt);{% endif %}">
          <div class="d-story-left">
            {%- if block.settings.caption != blank -%}
              <div class="d-sec-label">{{ block.settings.caption }}</div>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="d-sec-h" style="margin-bottom:24px">{{ block.settings.heading | replace: "<p>", "" | replace: "</p>", "" }}</h2>
            {%- endif -%}
            <div>{{ block.settings.text }}</div>
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link | default: '#' }}" class="d-btn-t" style="margin-top:24px">{{ block.settings.button_label }} →</a>
            {%- endif -%}
          </div>
          <div class="d-story-right">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag:
                loading: 'lazy', class: 'd-story-img', alt: block.settings.image.alt | default: block.settings.heading
              }}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'd-story-img placeholder-svg' }}
            {%- endif -%}
          </div>
        </section>

      {%- when 'page_intro' -%}
        {%- if block.settings.heading != blank or block.settings.text != blank -%}
          <section class="d-pullquote d-reveal">
            <div class="d-pq-line"></div>
            <div>
              {%- if block.settings.heading != blank -%}
                <div class="d-pq-text" style="font-style:normal;color:var(--d-black);font-size:clamp(28px,3vw,42px);font-weight:300;">{{ block.settings.heading | replace: "<p>", "" | replace: "</p>", "" }}</div>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="d-pq-attr" style="font-size:15px;color:var(--d-mid);line-height:1.85;margin-top:18px;max-width:720px">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>
          </section>
        {%- endif -%}

    {%- endcase -%}
  {%- endfor -%}

</div>

{% schema %}
{
  "name": "Divine Story Page",
  "tag": "section",
  "class": "divine-story-page-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Page hero heading size",
      "min": 24,
      "max": 120,
      "step": 1,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Caption font size",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "item_heading_font_size",
      "label": "Card heading font size",
      "min": 14,
      "max": 48,
      "step": 1,
      "default": 24,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "intro",
      "name": "Page hero",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "About Divine Ingredients" },
        { "type": "html", "id": "heading", "label": "Heading", "default": "<p>When you know better, you <em>choose better.</em></p>" },
        { "type": "html", "id": "text", "label": "Intro text", "default": "<p>The story of a microbiologist who turned a habit of reading labels into a brand built entirely on the truth of what's inside.</p>" },
        { "type": "image_picker", "id": "image", "label": "Founder photo" },
        { "type": "text", "id": "placeholder_text", "label": "Photo placeholder text", "default": "Preet's photo coming soon" },
        { "type": "text", "id": "cap_name", "label": "Caption name", "default": "Preet Bhullar" },
        { "type": "text", "id": "cap_role", "label": "Caption role", "default": "Founder · Microbiologist" }
      ]
    },
    {
      "type": "pull_quote",
      "name": "Pull quote",
      "limit": 2,
      "settings": [
        { "type": "html", "id": "quote", "label": "Quote", "default": "<p>\"Divine Ingredients began, as many good things do, with a simple habit — turning the label over and asking, 'but what's really in this?'\"</p>" },
        { "type": "text", "id": "attribution", "label": "Attribution", "default": "Preet Bhullar, Founder" }
      ]
    },
    {
      "type": "story_body",
      "name": "Story body",
      "settings": [
        { "type": "html", "id": "text", "label": "Body text",
          "default": "<p>For me, that question wasn't fleeting curiosity. With a background in microbiology and quality control, I knew exactly what to look for — and more importantly, what didn't belong.</p><p>So I set a new standard. One rooted in honesty, not marketing. <strong>No filters, no shortcuts.</strong> Just what nature meant, thoughtfully refined.</p><p>Because when you know better, you choose better. And once you taste the difference, there's no going back.</p>"
        },
        { "type": "header", "content": "Sidebar card 1" },
        { "type": "text", "id": "card_1_label", "label": "Label", "default": "Background" },
        { "type": "html", "id": "card_1_value", "label": "Value", "default": "<p><em>Microbiology</em></p>" },
        { "type": "text", "id": "card_1_desc", "label": "Description", "default": "Quality control expertise. She knows exactly what belongs — and what doesn't." },
        { "type": "header", "content": "Sidebar card 2" },
        { "type": "text", "id": "card_2_label", "label": "Label", "default": "Founded on" },
        { "type": "html", "id": "card_2_value", "label": "Value", "default": "<p><em>Honesty</em></p>" },
        { "type": "text", "id": "card_2_desc", "label": "Description", "default": "Not marketing. Not buzzwords. What's on the label is exactly what's inside." },
        { "type": "header", "content": "Sidebar card 3 (optional)" },
        { "type": "text", "id": "card_3_label", "label": "Label" },
        { "type": "html", "id": "card_3_value", "label": "Value" },
        { "type": "text", "id": "card_3_desc", "label": "Description" }
      ]
    },
    {
      "type": "values",
      "name": "Values 3-column",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "What we stand for" },
        { "type": "html", "id": "heading", "label": "Heading", "default": "<p>Our <em>values</em></p>" },
        { "type": "header", "content": "Value 1" },
        { "type": "html", "id": "value_1_title", "label": "Title", "default": "<p><em>Honesty</em> over marketing</p>" },
        { "type": "html", "id": "value_1_body", "label": "Body", "default": "<p>We don't dress up mediocre ingredients with clever language. What's on the label is exactly what's in the bag — nothing more, nothing less.</p>" },
        { "type": "header", "content": "Value 2" },
        { "type": "html", "id": "value_2_title", "label": "Title", "default": "<p>Rigour without <em>compromise</em></p>" },
        { "type": "html", "id": "value_2_body", "label": "Body", "default": "<p>Every batch is independently tested by a third-party lab before it ships. USDA Organic, CCOF Certified, Non-GMO — the minimum we accept.</p>" },
        { "type": "header", "content": "Value 3" },
        { "type": "html", "id": "value_3_title", "label": "Title", "default": "<p>Sourcing with <em>intention</em></p>" },
        { "type": "html", "id": "value_3_body", "label": "Body", "default": "<p>We go directly to the farms — Japan, India, Sri Lanka, and beyond. No brokers. No mystery. Full traceability, every time.</p>" }
      ]
    },
    {
      "type": "certs_grid",
      "name": "Certifications grid",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Certifications & standards" },
        { "type": "html", "id": "heading", "label": "Heading", "default": "<p>Every claim, <em>verified.</em></p>" },
        { "type": "header", "content": "Cert 1" },
        { "type": "text", "id": "cert_1_title", "label": "Title", "default": "USDA Organic" },
        { "type": "html", "id": "cert_1_body", "label": "Body", "default": "<p>Certified to the highest US organic standards. Audited, verified, and renewed annually.</p>" },
        { "type": "header", "content": "Cert 2" },
        { "type": "text", "id": "cert_2_title", "label": "Title", "default": "CCOF Certified" },
        { "type": "html", "id": "cert_2_body", "label": "Body", "default": "<p>California Certified Organic Farmers — one of the most rigorous certifications in North America.</p>" },
        { "type": "header", "content": "Cert 3" },
        { "type": "text", "id": "cert_3_title", "label": "Title", "default": "Lab Tested Every Batch" },
        { "type": "html", "id": "cert_3_body", "label": "Body", "default": "<p>Third-party independent testing for purity, potency, and safety. Certificate of Analysis available on request.</p>" },
        { "type": "header", "content": "Cert 4" },
        { "type": "text", "id": "cert_4_title", "label": "Title", "default": "Non-GMO · Fair Trade · Rainforest Alliance" },
        { "type": "html", "id": "cert_4_body", "label": "Body", "default": "<p>Sourced responsibly, from farms that treat people and land with the same care we put into every product.</p>" }
      ]
    },
    {
      "type": "cta",
      "name": "CTA band",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Ready to explore?" },
        { "type": "html", "id": "heading", "label": "Heading", "default": "<p>Taste the<br><em>difference honesty makes.</em></p>" },
        { "type": "html", "id": "text", "label": "Body", "default": "<p>36 teas, 14 superfood powders, spices, and botanicals — all sourced with the same intention and tested to the same standard.</p>" },
        { "type": "text", "id": "button_label_1", "label": "Primary button label", "default": "Shop All Products" },
        { "type": "url", "id": "button_link_1", "label": "Primary button link" },
        { "type": "text", "id": "button_label_2", "label": "Secondary button label", "default": "Try the Discovery Set — $38" },
        { "type": "url", "id": "button_link_2", "label": "Secondary button link" },
        { "type": "text", "id": "button_label_3", "label": "Tertiary button label", "default": "Wholesale enquiries" },
        { "type": "url", "id": "button_link_3", "label": "Tertiary button link" },
        { "type": "checkbox", "id": "use_dark_bg", "label": "Use dark background (legacy)", "default": true }
      ]
    },
    {
      "type": "image_text",
      "name": "Legacy image+text",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "html", "id": "text", "label": "Text" },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "button_link", "label": "Button link" },
        { "type": "select", "id": "layout", "label": "Layout",
          "options": [
            { "value": "image_right", "label": "Image right" },
            { "value": "image_left", "label": "Image left" }
          ],
          "default": "image_right"
        },
        { "type": "checkbox", "id": "use_alt_bg", "label": "Use alternate background", "default": false }
      ]
    },
    {
      "type": "page_intro",
      "name": "Page intro (legacy)",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "html", "id": "text", "label": "Intro text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Story Page",
      "blocks": [
        { "type": "intro" },
        { "type": "pull_quote" },
        { "type": "story_body" },
        { "type": "values" },
        { "type": "certs_grid" },
        { "type": "cta" }
      ]
    }
  ]
}
{% endschema %}
