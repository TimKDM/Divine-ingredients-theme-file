{%- comment -%}
  Divine Powders Split. Image left + numbered list right
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .d-powders{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  #shopify-section-{{ section.id }} .d-powders-body{
    padding-top: {{ section.settings.padding_top | default: 88 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 88 }}px;
    {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}background:{{ section.settings.background_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .d-sec-h{
    font-size: {{ section.settings.heading_font_size | default: 52 }}px;
  }
  #shopify-section-{{ section.id }} .d-sec-label{
    font-size: {{ section.settings.caption_font_size | default: 11 }}px;
  }
{%- endstyle -%}

{%- liquid
  assign use_collage = false
  if section.settings.image_2 != blank or section.settings.image_3 != blank or section.settings.image_4 != blank
    assign use_collage = true
  endif
  assign use_collage_9 = false
  if section.settings.image_5 != blank or section.settings.image_6 != blank or section.settings.image_7 != blank or section.settings.image_8 != blank or section.settings.image_9 != blank
    assign use_collage_9 = true
  endif
-%}

<section class="d-powders d-reveal{% if use_collage or use_collage_9 %} d-powders--collage{% endif %}">
  <div class="d-powders-img-wrap">
    {%- if use_collage_9 -%}
      <div class="d-powders-collage d-powders-collage--9">
        {%- for i in (1..9) -%}
          {%- if i == 1 -%}
            {%- assign img = section.settings.image -%}
          {%- else -%}
            {%- assign img = section.settings['image_' | append: i] -%}
          {%- endif -%}
          <div class="d-powders-tile">
            {%- if img != blank -%}
              {{ img | image_url: width: 500 | image_tag:
                loading: 'lazy', widths: '250, 350, 500',
                sizes: '(min-width: 1100px) 17vw, 33vw',
                class: 'd-powders-tile-img', alt: img.alt | default: section.settings.title
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'd-powders-tile-img placeholder-svg' }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- elsif use_collage -%}
      <div class="d-powders-collage">
        <div class="d-powders-tile">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 700 | image_tag:
              loading: 'lazy', widths: '350, 500, 700',
              sizes: '(min-width: 1100px) 25vw, 50vw',
              class: 'd-powders-tile-img', alt: section.settings.image.alt | default: section.settings.title
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'd-powders-tile-img placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="d-powders-tile">
          {%- if section.settings.image_2 != blank -%}
            {{ section.settings.image_2 | image_url: width: 700 | image_tag:
              loading: 'lazy', widths: '350, 500, 700',
              sizes: '(min-width: 1100px) 25vw, 50vw',
              class: 'd-powders-tile-img', alt: section.settings.image_2.alt
            }}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'd-powders-tile-img placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="d-powders-tile">
          {%- if section.settings.image_3 != blank -%}
            {{ section.settings.image_3 | image_url: width: 700 | image_tag:
              loading: 'lazy', widths: '350, 500, 700',
              sizes: '(min-width: 1100px) 25vw, 50vw',
              class: 'd-powders-tile-img', alt: section.settings.image_3.alt
            }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'd-powders-tile-img placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="d-powders-tile">
          {%- if section.settings.image_4 != blank -%}
            {{ section.settings.image_4 | image_url: width: 700 | image_tag:
              loading: 'lazy', widths: '350, 500, 700',
              sizes: '(min-width: 1100px) 25vw, 50vw',
              class: 'd-powders-tile-img', alt: section.settings.image_4.alt
            }}
          {%- else -%}
            {{ 'product-2' | placeholder_svg_tag: 'd-powders-tile-img placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag:
        loading: 'lazy', widths: '500, 750, 1000, 1400', sizes: '(min-width: 1100px) 50vw, 100vw',
        class: 'd-powders-img', alt: section.settings.image.alt | default: section.settings.title
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'd-powders-img placeholder-svg' }}
    {%- endif -%}
  </div>
  <div class="d-powders-body">
    {%- if section.settings.caption != blank -%}
      <div class="d-sec-label">{{ section.settings.caption }}</div>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="d-sec-h" style="margin-bottom:16px">{{ section.settings.title | replace: '<p>', '' | replace: '</p>', '' }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="d-sec-p" style="margin-bottom:36px;max-width:400px">{{ section.settings.text }}</p>
    {%- endif -%}

    <div class="d-powder-list">
      {%- for block in section.blocks -%}
        {%- assign row_link = block.settings.link | default: '#' -%}
        {%- if block.settings.collection != blank and block.settings.link == blank -%}
          {%- assign row_link = block.settings.collection.url -%}
        {%- endif -%}
        <a href="{{ row_link }}" class="d-powder-row" {{ block.shopify_attributes }}>
          <span class="d-pr-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <div>
            <div class="d-pr-title">{{ block.settings.title | default: block.settings.collection.title }}</div>
            <div class="d-pr-desc">{{ block.settings.description }}</div>
          </div>
          <span class="d-pr-arrow">→</span>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '/collections/powders' }}" class="d-btn-t">{{ section.settings.button_label }} →</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Powders",
  "tag": "section",
  "class": "divine-powders-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image 1 (single image, or top-left collage tile)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (top-right tile) — adding this triggers 2×2 collage layout"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (bottom-left tile)"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4 (bottom-right tile)"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Image 5 — adding image 5+ triggers a 3×3 (9-image) collage"
    },
    {
      "type": "image_picker",
      "id": "image_6",
      "label": "Image 6 (3×3 collage)"
    },
    {
      "type": "image_picker",
      "id": "image_7",
      "label": "Image 7 (3×3 collage)"
    },
    {
      "type": "image_picker",
      "id": "image_8",
      "label": "Image 8 (3×3 collage)"
    },
    {
      "type": "image_picker",
      "id": "image_9",
      "label": "Image 9 (3×3 collage)"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption / kicker",
      "default": "Daily superfoods"
    },
    {
      "type": "html",
      "id": "title",
      "label": "Title",
      "default": "<p>Superfood<br><em>powders</em></p>"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Mushroom powders, fruit powders, and superfoods for smoothies, lattes, and cooking. Every one independently lab tested. No filters, nothing added."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Bottom button label",
      "default": "Browse all powders"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Bottom button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Right-side background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 88,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 24,
      "max": 80,
      "step": 1,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Caption font size",
      "min": 8,
      "max": 18,
      "step": 1,
      "default": 11,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "powder",
      "name": "Powder row",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title", "default": "Mushroom Powders" },
        { "type": "text", "id": "description", "label": "Description", "default": "Lion's Mane · Reishi · Cordyceps" },
        { "type": "url", "id": "link", "label": "Custom link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Powders",
      "blocks": [
        { "type": "powder", "settings": { "title": "Mushroom Powders", "description": "Lion's Mane · Reishi · Cordyceps" } },
        { "type": "powder", "settings": { "title": "Fruit Powders", "description": "Blueberry · Taro · Tart Cherries · Rose Petals · Date" } },
        { "type": "powder", "settings": { "title": "Superfood Blends", "description": "Ashwagandha · Rhodiola · Coconut Milk · Molasses · Coffee Cherry" } }
      ]
    }
  ]
}
{% endschema %}
