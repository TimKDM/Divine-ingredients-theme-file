{%- style -%}
  #shopify-section-{{ section.id }} .d-cfilters-sec {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .d-cfilters-sec {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} .d-cfilters-sec {
    font-size: {{ section.settings.body_font_size | default: 14 }}px;
  }
  #shopify-section-{{ section.id }} .d-cfilter-group-title {
    font-size: {{ section.settings.heading_font_size | default: 16 }}px;
  }
{%- endstyle -%}

<section class="d-cfilters-sec page-width">
  {%- if section.settings.title != blank -%}
    <h3 class="d-cfilter-group-title" style="margin-bottom: var(--spacing-sm);">{{ section.settings.title }}</h3>
  {%- endif -%}

  {% render 'divine-collection-filters',
    collection: collection,
    current_tags: current_tags
  %}
</section>

{% schema %}
{
  "name": "Divine Collection Filters",
  "tag": "section",
  "class": "divine-collection-filters-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Filter by"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 10,
      "max": 22,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "default": 16,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Divine Collection Filters",
      "settings": {
        "title": "Filter by",
        "padding_top": 16,
        "padding_bottom": 8
      }
    }
  ]
}
{% endschema %}
