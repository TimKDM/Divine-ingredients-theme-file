{%- comment -%}
  Divine Ticker — forest green marquee bar
  Repurposed from the previous trust-bar block list so existing JSON keeps working.
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .d-ticker{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    padding-top: {{ section.settings.padding_top | default: 11 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 11 }}px;
    {% if section.settings.background_color != blank %}background:{{ section.settings.background_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .d-ti{
    font-size: {{ section.settings.body_font_size | default: 11 }}px;
    {% if section.settings.text_color != blank %}color:{{ section.settings.text_color }};{% endif %}
  }
{%- endstyle -%}

<div class="d-ticker" aria-hidden="true">
  <div class="d-ticker-inner">
    {%- for pass in (1..2) -%}
      {%- for block in section.blocks -%}
        <div class="d-ti" {{ block.shopify_attributes }}>
          <span class="d-ti-dot"></span>
          {{- block.settings.text | replace: '<strong>', '' | replace: '</strong>', '' | strip_html | strip -}}
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Divine Ticker",
  "tag": "section",
  "class": "divine-ticker-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Text size",
      "min": 8,
      "max": 18,
      "step": 1,
      "default": 11,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Ticker item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield / Certified" },
            { "value": "package", "label": "Package / Shipping" },
            { "value": "star", "label": "Star / Rating" },
            { "value": "dollar", "label": "Dollar / Pricing" },
            { "value": "leaf", "label": "Leaf / Organic" },
            { "value": "truck", "label": "Truck / Delivery" },
            { "value": "check", "label": "Check / Verified" },
            { "value": "woman", "label": "Woman / Founder" }
          ],
          "default": "shield"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom icon image"
        },
        {
          "type": "html",
          "id": "text",
          "label": "Text",
          "default": "USDA Organic"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Ticker",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "USDA Organic" } },
        { "type": "trust_item", "settings": { "text": "CCOF Certified" } },
        { "type": "trust_item", "settings": { "text": "Every Batch Lab Tested" } },
        { "type": "trust_item", "settings": { "text": "Non-GMO" } },
        { "type": "trust_item", "settings": { "text": "Fair Trade" } },
        { "type": "trust_item", "settings": { "text": "Rainforest Alliance" } },
        { "type": "trust_item", "settings": { "text": "Woman Owned & Operated" } },
        { "type": "trust_item", "settings": { "text": "Free Shipping Over $100" } }
      ]
    }
  ]
}
{% endschema %}
