{%- comment -%}
  Divine Announce Bar. Top dark bar with promo + link
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .d-announce{
    {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}background:{{ section.settings.background_color }};{% endif %}
    {% if section.settings.text_color != blank %}color:{{ section.settings.text_color }};{% endif %}
    font-size: {{ section.settings.font_size | default: 12 }}px;
    padding-top: {{ section.settings.padding_top | default: 10 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 10 }}px;
  }
{%- endstyle -%}

<div class="d-announce">
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'message' -%}
        <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      {%- when 'separator' -%}
        <span {{ block.shopify_attributes }}>·</span>
      {%- when 'promo_code' -%}
        <span {{ block.shopify_attributes }}>{{ block.settings.prefix }} <strong>{{ block.settings.code }}</strong> {{ block.settings.suffix }}</span>
      {%- when 'link' -%}
        <a href="{{ block.settings.link | default: '/collections/all' }}" {{ block.shopify_attributes }}>{{ block.settings.text }} →</a>
    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Divine Announce",
  "tag": "section",
  "class": "divine-announce-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 10,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 10,
      "unit": "px"
    }
  ],
  "blocks": [
    { "type": "message", "name": "Message",
      "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Free Shipping on Orders Over $100" }] },
    { "type": "separator", "name": "Separator (·)", "settings": [] },
    { "type": "promo_code", "name": "Promo code",
      "settings": [
        { "type": "text", "id": "prefix", "label": "Prefix", "default": "Use" },
        { "type": "text", "id": "code", "label": "Code", "default": "WELCOME" },
        { "type": "text", "id": "suffix", "label": "Suffix", "default": "for 20% off your first order" }
      ] },
    { "type": "link", "name": "Link",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Shop now" },
        { "type": "url", "id": "link", "label": "Link" }
      ] }
  ],
  "presets": [
    {
      "name": "Divine Announce",
      "blocks": [
        { "type": "message" },
        { "type": "separator" },
        { "type": "promo_code" },
        { "type": "link" }
      ]
    }
  ]
}
{% endschema %}
