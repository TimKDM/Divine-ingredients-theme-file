{%- style -%}
  #shopify-section-{{ section.id }} .d-story{
    {% if section.settings.background_color != blank %}background-color: {{ section.settings.background_color }};{% endif %}
    padding-top: 0;
    padding-bottom: 0;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  #shopify-section-{{ section.id }} .d-story-left,
  #shopify-section-{{ section.id }} .d-story-right{
    padding-top: {{ section.settings.padding_top | default: 96 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 96 }}px;
  }
  #shopify-section-{{ section.id }} .d-story-body{
    font-size: {{ section.settings.body_font_size | default: 15 }}px;
  }
  #shopify-section-{{ section.id }} .d-story-pull{
    font-size: {{ section.settings.item_heading_font_size | default: 22 }}px;
  }
  {% if section.settings.text_color != blank %}
  #shopify-section-{{ section.id }} .d-story-body{ color: {{ section.settings.text_color }}; }
  {% endif %}
{%- endstyle -%}

<section class="d-story d-reveal">
  <div class="d-story-left">
    {%- if section.settings.caption != blank -%}
      <div class="d-sec-label">{{ section.settings.caption }}</div>
    {%- endif -%}
    {%- if section.settings.pull_quote != blank -%}
      <div class="d-story-pull">{{ section.settings.pull_quote }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="d-sec-h" style="margin-bottom:24px">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="d-story-body-wrap">
        {{ section.settings.text | replace: '<p>', '<p class="d-story-body">' }}
      </div>
    {%- endif -%}
    {%- if section.settings.signature != blank -%}
      <div class="d-story-sig">{{ section.settings.signature }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '/pages/about-us' }}" class="d-btn-t">{{ section.settings.button_label }} →</a>
    {%- endif -%}
  </div>
  <div class="d-story-right">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1200 | image_tag:
        loading: 'lazy', widths: '500, 750, 1000, 1200', sizes: '(min-width: 1100px) 50vw, 100vw',
        class: 'd-story-img', alt: section.settings.image.alt | default: section.settings.cap_name | default: 'Founder image'
      }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'd-story-img placeholder-svg' }}
    {%- endif -%}
    {%- if section.settings.cap_name != blank or section.settings.cap_role != blank -%}
      <div class="d-story-cap">
        {%- if section.settings.cap_label != blank -%}
          <div class="d-story-cap-label">{{ section.settings.cap_label }}</div>
        {%- endif -%}
        {%- if section.settings.cap_name != blank or section.settings.cap_role != blank -%}
          <div class="d-story-cap-text">
            {%- if section.settings.cap_name != blank -%}<em>{{ section.settings.cap_name }}</em>{%- endif -%}
            {%- if section.settings.cap_role != blank -%}<br>{{ section.settings.cap_role }}{%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Brand Story",
  "tag": "section",
  "class": "divine-brand-story-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right-side image"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption / kicker",
      "default": "Our Story"
    },
    {
      "type": "html",
      "id": "pull_quote",
      "label": "Pull quote (italic)",
      "default": "\"…turning the label over and asking,<br>'but what's really in this?'\""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "html",
      "id": "text",
      "label": "Body text",
      "default": "<p>Divine Ingredients began, as many good things do, with a simple habit. For Preet Bhullar, that question wasn't fleeting curiosity. With a background in microbiology and quality control, she knew exactly what to look for — and more importantly, what didn't belong.</p><p>So she set a new standard. One rooted in honesty, not marketing. Every ingredient is sourced with intention, tested with rigour, and chosen because it earns its place.</p><p>Because when you know better, you choose better. And once you taste the difference, there's no going back.</p>"
    },
    {
      "type": "html",
      "id": "signature",
      "label": "Signature line",
      "default": "— <em>Preet Bhullar,</em> Founder"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read our story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background (legacy)"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button text color (legacy)"
    },
    {
      "type": "header",
      "content": "Image caption"
    },
    {
      "type": "text",
      "id": "cap_label",
      "label": "Caption label",
      "default": "Founded by"
    },
    {
      "type": "text",
      "id": "cap_name",
      "label": "Caption name",
      "default": "Preet Bhullar"
    },
    {
      "type": "text",
      "id": "cap_role",
      "label": "Caption role",
      "default": "Microbiologist & Founder"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 96,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 72,
      "step": 1,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "item_heading_font_size",
      "label": "Pull quote size",
      "min": 14,
      "max": 36,
      "step": 1,
      "default": 22,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Brand Value (legacy)",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "globe", "label": "Globe" },
            { "value": "clipboard", "label": "Clipboard" },
            { "value": "dollar", "label": "Dollar" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "heart", "label": "Heart" }
          ], "default": "shield"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Certified Organic" },
        { "type": "text", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Brand Story",
      "settings": {
        "caption": "Our Story",
        "heading": ""
      }
    }
  ]
}
{% endschema %}
