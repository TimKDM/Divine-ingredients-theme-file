{%- style -%}
  #shopify-section-{{ section.id }} .divine-section {
    background-color: {{ section.settings.background_color }};
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    padding-top: {{ section.settings.padding_top | times: 0.75 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 }}px;
  }

  #shopify-section-{{ section.id }} .divine-section-label {
    color: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .divine-section-title {
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .divine-testimonial-card {
    background-color: {{ section.settings.card_background_color }};
    border-color: {{ section.settings.card_border_color }};
  }

  #shopify-section-{{ section.id }} .divine-testimonial-stars svg {
    fill: {{ section.settings.star_color }};
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .divine-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="divine-section{% if section.settings.use_alt_bg %} divine-section-alt{% endif %}">
  <div class="divine-section-header">
    {%- if section.settings.caption != blank -%}
      <span class="divine-section-label">{{ section.settings.caption }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="divine-section-title">{{ section.settings.title }}</h2>
    {%- endif -%}
  </div>

  <div class="divine-testimonial-grid">
    {%- for block in section.blocks -%}
      <div class="divine-testimonial-card" {{ block.shopify_attributes }}>
        {%- if block.settings.rating != blank -%}
          <div class="divine-testimonial-stars">
            {%- assign star_count = block.settings.rating | plus: 0 -%}
            {%- for i in (1..star_count) -%}
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
            {%- if block.settings.source != blank -%}
              <span class="divine-testimonial-source">{{ block.settings.source }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if block.settings.text != blank -%}
          <p class="divine-testimonial-text">"{{ block.settings.text }}"</p>
        {%- endif -%}

        <div class="divine-testimonial-footer">
          <div class="divine-testimonial-avatar">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 96 | image_tag: loading: 'lazy', widths: '48, 96' }}
            {%- else -%}
              <span class="divine-testimonial-initial">{{ block.settings.author | slice: 0 }}</span>
            {%- endif -%}
          </div>
          <div class="divine-testimonial-meta">
            {%- if block.settings.author != blank -%}
              <p class="divine-testimonial-author">
                {{ block.settings.author }}
                <svg class="divine-verified-badge" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
              </p>
            {%- endif -%}
            {%- if block.settings.role != blank -%}
              <p class="divine-testimonial-role">{{ block.settings.role }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Testimonials",
  "tag": "section",
  "class": "divine-testimonials-section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Trusted by Wellness Lovers & Business Owners"
    },
    {
      "type": "checkbox",
      "id": "use_alt_bg",
      "label": "Use alternate background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "The matcha is the real deal. Our customers notice the difference and so do we."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role / Location",
          "default": "Café Owner, Portland"
        },
        {
          "type": "text",
          "id": "source",
          "label": "Review source (e.g. Google, Shopify)",
          "default": "Google Review"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Author photo (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "The matcha is the real deal. Our customers notice the difference and so do we. We've tried four other suppliers — this is the one we kept.",
            "author": "Sarah M.",
            "role": "Café Owner, Portland",
            "source": "Google Review"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "I stock Divine turmeric and their superfood blends in my practice. Lab-tested, consistent quality, and my clients trust the sourcing. That matters.",
            "author": "Dr. James K.",
            "role": "Naturopathic Practitioner, Vancouver",
            "source": "Wholesale Partner"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Switched from a big-box brand and the difference is night and day. The cinnamon, the vanilla, the matcha — everything actually tastes like the real thing.",
            "author": "Michelle T.",
            "role": "Recipe Creator & Home Baker",
            "source": "Shopify Review"
          }
        }
      ]
    }
  ]
}
{% endschema %}
