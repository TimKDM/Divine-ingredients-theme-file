{{ 'divine-mockup-v3.css' | asset_url | stylesheet_tag }}

<section class="divine-section divine-section-alt">
  <div class="divine-section-header">
    {%- if section.settings.caption != blank -%}
      <span class="divine-section-label">{{ section.settings.caption }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="divine-section-title">{{ section.settings.title }}</h2>
    {%- endif -%}
  </div>

  <div class="divine-testimonial-scroll">
    {%- for block in section.blocks -%}
      <div class="divine-testimonial-card" {{ block.shopify_attributes }}>
        {%- if block.settings.rating != blank -%}
          <div class="divine-testimonial-stars">
            {%- assign star_count = block.settings.rating | plus: 0 -%}
            {%- for i in (1..star_count) -%}
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if block.settings.text != blank -%}
          <p class="divine-testimonial-text">"{{ block.settings.text }}"</p>
        {%- endif -%}

        {%- if block.settings.author != blank -%}
          <p class="divine-testimonial-author">{{ block.settings.author }}</p>
        {%- endif -%}

        {%- if block.settings.role != blank -%}
          <p class="divine-testimonial-role">{{ block.settings.role }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Divine Testimonials",
  "tag": "section",
  "class": "divine-testimonials-section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "What People Say"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Customer Reviews"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "The ceremonial matcha is the best I've found outside of Japan. Our café customers always ask what brand we use."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role / Location",
          "default": "Café Owner, Portland"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "The ceremonial matcha is the best I've found outside of Japan. Our café customers always ask what brand we use.",
            "author": "Sarah M.",
            "role": "Café Owner, Portland"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Finally found a reliable source for organic turmeric. The quality is consistent and the bulk pricing is perfect.",
            "author": "Dr. James K.",
            "role": "Wellness Practitioner"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "The chai blend has become my morning ritual. The spice balance is perfect and the aroma is incredible!",
            "author": "Michelle T.",
            "role": "Tea Enthusiast"
          }
        }
      ]
    }
  ]
}
{% endschema %}
