{%- style -%}
  .divine-wholesale-form-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  @media screen and (min-width: 768px) {
    .divine-wholesale-form-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .divine-wholesale-form-wrap {
    font-family: 'Jost', var(--font-body-family), sans-serif;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .divine-wholesale-form__intro {
    text-align: center;
    margin-bottom: 40px;
  }
  .divine-wholesale-form__intro .divine-section-label {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent-dark, #9b76a7);
    display: block;
    margin-bottom: 10px;
  }
  .divine-wholesale-form__intro h1,
  .divine-wholesale-form__intro h2 {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: clamp(28px, 4.5vw, 38px);
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }
  .divine-wholesale-form__intro p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-text-muted, #7a6f64);
    max-width: 640px;
    margin: 0 auto 14px;
  }
  .divine-wholesale-form__intro p:last-child {
    margin-bottom: 0;
  }

  .divine-wholesale-form-card {
    background: var(--color-background-hex, #ffffff);
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 4px 32px rgba(0,0,0,0.06);
    border: 1px solid var(--color-border-hex, #d2c4d7);
  }
  @media screen and (max-width: 767px) {
    .divine-wholesale-form-card {
      padding: 24px;
    }
  }

  .divine-wholesale-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }
  @media screen and (min-width: 640px) {
    .divine-wholesale-form__row--2 {
      grid-template-columns: 1fr 1fr;
    }
    .divine-wholesale-form__row--3 {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .divine-wholesale-form__field {
    display: flex;
    flex-direction: column;
  }
  .divine-wholesale-form__label {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
    color: rgb(var(--color-foreground));
  }
  .divine-wholesale-form__label .req {
    color: #c0392b;
    margin-left: 3px;
  }
  .divine-wholesale-form__input,
  .divine-wholesale-form__select,
  .divine-wholesale-form__textarea {
    width: 100%;
    padding: 12px 14px;
    font-size: 16px;
    font-family: 'Jost', var(--font-body-family), sans-serif;
    border: 1px solid rgba(var(--color-base-border-1));
    border-radius: 6px;
    background: transparent;
    color: rgb(var(--color-foreground));
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    box-sizing: border-box;
  }
  .divine-wholesale-form__textarea {
    min-height: 140px;
    resize: vertical;
  }
  .divine-wholesale-form__select {
    cursor: pointer;
  }
  .divine-wholesale-form__input:focus,
  .divine-wholesale-form__select:focus,
  .divine-wholesale-form__textarea:focus {
    border-color: var(--color-accent-dark, #9b76a7);
    outline: none;
    box-shadow: 0 0 0 3px rgba(155, 118, 167, 0.12);
  }

  .divine-wholesale-form__group {
    margin-bottom: 24px;
  }
  .divine-wholesale-form__group-label {
    font-family: 'Josefin Sans', var(--font-heading-family), sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 12px;
    color: rgb(var(--color-foreground));
    display: block;
  }
  .divine-wholesale-form__group-label .req {
    color: #c0392b;
    margin-left: 3px;
  }

  .divine-wholesale-form__radios {
    display: flex;
    flex-wrap: wrap;
    gap: 14px 22px;
  }
  .divine-wholesale-form__radio {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    cursor: pointer;
  }
  .divine-wholesale-form__radio input[type="radio"] {
    accent-color: var(--color-accent-dark, #9b76a7);
    width: 16px;
    height: 16px;
  }

  .divine-wholesale-form__checks {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }
  @media screen and (min-width: 640px) {
    .divine-wholesale-form__checks {
      grid-template-columns: 1fr 1fr;
    }
  }
  .divine-wholesale-form__check {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    line-height: 1.4;
    cursor: pointer;
  }
  .divine-wholesale-form__check input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-accent-dark, #9b76a7);
  }

  .divine-wholesale-form__submit-row {
    margin-top: 28px;
    text-align: center;
  }
  .divine-wholesale-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 240px;
    min-height: 48px;
    padding: 14px 36px;
    font-family: 'Josefin Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--color-accent-dark, #9b76a7);
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.15s ease;
  }
  .divine-wholesale-form__submit:hover {
    background: #7e5b8d;
    transform: translateY(-1px);
  }
  .divine-wholesale-form__note {
    font-size: 14px;
    color: var(--color-text-muted, #7a6f64);
    margin-top: 14px;
    line-height: 1.5;
  }

  .divine-wholesale-form__status {
    padding: 16px 20px;
    border-radius: 8px;
    margin-bottom: 24px;
    font-size: 16px;
  }
  .divine-wholesale-form__status--success {
    background: #ecf7ed;
    color: #2f6d33;
    border: 1px solid #b8dbb9;
  }
  .divine-wholesale-form__status--error {
    background: #fdecea;
    color: #a0332a;
    border: 1px solid #f1b6b0;
  }
  .divine-wholesale-form__status ul {
    margin: 8px 0 0;
    padding-left: 20px;
  }
{%- endstyle -%}

<section class="divine-wholesale-form-wrap" id="wholesale-form">

  {%- if section.settings.heading != blank or section.settings.label != blank or section.settings.subtext != blank -%}
    <div class="divine-wholesale-form__intro">
      {%- if section.settings.label != blank -%}
        <span class="divine-section-label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <div>{{ section.settings.subtext }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="divine-wholesale-form-card">
    {%- form 'contact', id: 'WholesaleForm' -%}

      {%- if form.posted_successfully? -%}
        <div class="divine-wholesale-form__status divine-wholesale-form__status--success" role="status">
          <strong>Thank you — your trade inquiry has been received.</strong>
          <div>A member of our wholesale team will be in touch within 1–2 business days.</div>
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="divine-wholesale-form__status divine-wholesale-form__status--error" role="alert">
          <strong>Please correct the following and try again:</strong>
          <ul>
            {%- for field in form.errors -%}
              <li>{{ form.errors.messages[field] }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <input type="hidden" name="contact[Form Type]" value="Wholesale / Trade Inquiry">

      <div class="divine-wholesale-form__row divine-wholesale-form__row--2">
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-first">First name<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="text" id="WholesaleForm-first" name="contact[First Name]" autocomplete="given-name" required>
        </div>
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-last">Last name<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="text" id="WholesaleForm-last" name="contact[Last Name]" autocomplete="family-name" required>
        </div>
      </div>

      {%- comment -%} Shopify's contact form expects a 'name' — combined from first + last on submit. {%- endcomment -%}
      <input type="hidden" name="contact[name]" id="WholesaleForm-name" value="">

      <div class="divine-wholesale-form__row">
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-company">Company (existing or anticipated name)<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="text" id="WholesaleForm-company" name="contact[Company Name]" required>
        </div>
      </div>

      <div class="divine-wholesale-form__row divine-wholesale-form__row--2">
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-email">Email<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="email" id="WholesaleForm-email" name="contact[email]" autocomplete="email" required>
        </div>
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-phone">Phone number<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="tel" id="WholesaleForm-phone" name="contact[Phone]" autocomplete="tel" required>
        </div>
      </div>

      <div class="divine-wholesale-form__row">
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-website">Website</label>
          <input class="divine-wholesale-form__input" type="url" id="WholesaleForm-website" name="contact[Website]" placeholder="https://">
        </div>
      </div>

      <div class="divine-wholesale-form__row">
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-address">Street address<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="text" id="WholesaleForm-address" name="contact[Street Address]" autocomplete="street-address" required>
        </div>
      </div>

      <div class="divine-wholesale-form__row divine-wholesale-form__row--2">
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-country">Country</label>
          <input class="divine-wholesale-form__input" type="text" id="WholesaleForm-country" name="contact[Country]" autocomplete="country-name">
        </div>
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-state">State / Province / Region<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="text" id="WholesaleForm-state" name="contact[State Or Region]" autocomplete="address-level1" required>
        </div>
      </div>

      <div class="divine-wholesale-form__row divine-wholesale-form__row--2">
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-city">City<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="text" id="WholesaleForm-city" name="contact[City]" autocomplete="address-level2" required>
        </div>
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-zip">Postal / Zip code<span class="req">*</span></label>
          <input class="divine-wholesale-form__input" type="text" id="WholesaleForm-zip" name="contact[Postal Code]" autocomplete="postal-code" required>
        </div>
      </div>

      <div class="divine-wholesale-form__group">
        <span class="divine-wholesale-form__group-label">Do you operate a business?<span class="req">*</span></span>
        <div class="divine-wholesale-form__radios">
          <label class="divine-wholesale-form__radio">
            <input type="radio" name="contact[Operates A Business]" value="Yes" required> Yes
          </label>
          <label class="divine-wholesale-form__radio">
            <input type="radio" name="contact[Operates A Business]" value="No"> No
          </label>
        </div>
      </div>

      <div class="divine-wholesale-form__group">
        <span class="divine-wholesale-form__group-label">Preferred contact method<span class="req">*</span></span>
        <div class="divine-wholesale-form__radios">
          <label class="divine-wholesale-form__radio">
            <input type="radio" name="contact[Preferred Contact Method]" value="Phone" required> Phone
          </label>
          <label class="divine-wholesale-form__radio">
            <input type="radio" name="contact[Preferred Contact Method]" value="Email"> Email
          </label>
          <label class="divine-wholesale-form__radio">
            <input type="radio" name="contact[Preferred Contact Method]" value="Text"> Text
          </label>
          <label class="divine-wholesale-form__radio">
            <input type="radio" name="contact[Preferred Contact Method]" value="WhatsApp"> WhatsApp
          </label>
        </div>
      </div>

      <div class="divine-wholesale-form__group">
        <span class="divine-wholesale-form__group-label">Which products are you interested in? (check all that apply)<span class="req">*</span></span>
        <div class="divine-wholesale-form__checks">
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Pyramid Tea Bag]" value="Yes"> Pyramid tea bag</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Nutrition & Wellness]" value="Yes"> Nutrition &amp; wellness</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - New Product Development]" value="Yes"> New product development</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Liquid IV]" value="Yes"> Liquid IV</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Functional Beverages]" value="Yes"> Functional beverages</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Custom Formulation Services]" value="Yes"> Custom formulation services</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Bulk Loose Tea]" value="Yes"> Bulk loose tea</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Bulk Ingredients]" value="Yes"> Bulk ingredients</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Custom Tea Blends]" value="Yes"> Custom tea blends</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Iced Tea Program]" value="Yes"> Iced tea program</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Contract Manufacturing]" value="Yes"> Contract manufacturing</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Co-Packing & Private Label]" value="Yes"> Co-packing &amp; private label</label>
          <label class="divine-wholesale-form__check"><input type="checkbox" name="contact[Interest - Stick Pack Format]" value="Yes"> Stick pack format</label>
        </div>
      </div>

      <div class="divine-wholesale-form__row">
        <div class="divine-wholesale-form__field">
          <label class="divine-wholesale-form__label" for="WholesaleForm-details">Enter details about your business</label>
          <textarea class="divine-wholesale-form__textarea" id="WholesaleForm-details" name="contact[body]" rows="6" placeholder="Tell us a bit about what you're working on, the volumes you have in mind, your timeline, and anything else you'd like us to know."></textarea>
        </div>
      </div>

      <div class="divine-wholesale-form__submit-row">
        <button type="submit" class="divine-wholesale-form__submit">Submit Trade Inquiry</button>
        {%- if section.settings.submit_note != blank -%}
          <p class="divine-wholesale-form__note">{{ section.settings.submit_note }}</p>
        {%- endif -%}
      </div>

    {%- endform -%}
  </div>
</section>

<script>
  (function () {
    var form = document.getElementById('WholesaleForm');
    if (!form) return;
    form.addEventListener('submit', function () {
      var first = form.querySelector('#WholesaleForm-first');
      var last = form.querySelector('#WholesaleForm-last');
      var nameField = form.querySelector('#WholesaleForm-name');
      if (first && last && nameField) {
        nameField.value = (first.value + ' ' + last.value).trim();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Divine Wholesale Form",
  "tag": "section",
  "class": "divine-wholesale-form-section",
  "settings": [
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Wholesale & Trade"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to get started?"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Intro copy",
      "default": "<p>Simply fill out the trade inquiry form below — tell us a bit about your business, your goals, and what you're looking for. Whether you're exploring wholesale opportunities, private-label options, custom blends, or just want to learn more about what we offer, we can't wait to connect.</p><p>Once submitted, our team will review your details and reach out promptly to begin the conversation. Let's connect, collaborate, and craft something extraordinary together.</p>"
    },
    {
      "type": "header",
      "content": "Footer"
    },
    {
      "type": "text",
      "id": "submit_note",
      "label": "Note under submit button",
      "default": "We review every inquiry personally. You'll hear back within 1–2 business days."
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Divine Wholesale Form"
    }
  ]
}
{% endschema %}
