{%- comment -%}
  Divine B2B Band. For cafés, spas, studios. Slim horizontal band.
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .d-b2b{
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
    padding-top: {{ section.settings.padding_top | default: 56 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 56 }}px;
    {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}background:{{ section.settings.background_color }};{% endif %}
  }
  #shopify-section-{{ section.id }} .d-b2b-h{
    font-size: {{ section.settings.heading_font_size | default: 28 }}px;
  }
  #shopify-section-{{ section.id }} .d-b2b-p{
    font-size: {{ section.settings.body_font_size | default: 14 }}px;
  }
{%- endstyle -%}

<section class="d-b2b d-reveal">
  <div>
    {%- if section.settings.caption != blank -%}
      <div class="d-sec-label">{{ section.settings.caption }}</div>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="d-b2b-h">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p class="d-b2b-p">{{ section.settings.text }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="d-b2b-pills">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div class="d-b2b-pill" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- if section.settings.button_label_1 != blank -%}
    <a href="{{ section.settings.button_link_1 | default: '/pages/wholesale' }}" class="d-btn-t" style="flex-shrink:0">{{ section.settings.button_label_1 }} →</a>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Divine Wholesale",
  "tag": "section",
  "class": "divine-wholesale-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (legacy, unused in band layout)"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption / kicker"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Wholesale & trade accounts"
    },
    {
      "type": "html",
      "id": "text",
      "label": "Body text",
      "default": "<p>Trusted by wellness businesses across North America. Same quality you love. Wholesale pricing, flexible minimums, and a Certificate of Analysis with every shipment.</p>"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary button label",
      "default": "Enquire about wholesale"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label (legacy)"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link (legacy)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 56,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "Body font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "default": 15,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading font size",
      "min": 18,
      "max": 80,
      "step": 1,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "caption_font_size",
      "label": "Caption font size",
      "min": 8,
      "max": 30,
      "step": 1,
      "default": 11,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "feature_font_size",
      "label": "Feature pill size",
      "min": 8,
      "max": 30,
      "step": 1,
      "default": 11,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature pill",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Wholesale pricing" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Wholesale",
      "blocks": [
        { "type": "feature", "settings": { "text": "Wholesale pricing" } },
        { "type": "feature", "settings": { "text": "Flexible MOQs" } },
        { "type": "feature", "settings": { "text": "Private label available" } },
        { "type": "feature", "settings": { "text": "COA with every order" } },
        { "type": "feature", "settings": { "text": "Dedicated account manager" } }
      ]
    }
  ]
}
{% endschema %}
