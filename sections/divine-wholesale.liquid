{%- style -%}
  .divine-wholesale-section {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  }
  @media screen and (min-width: 768px) {
    .divine-wholesale-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {% if section.settings.background_color != blank and section.settings.background_color != 'rgba(0,0,0,0)' %}
    .divine-wholesale {
      background-color: {{ section.settings.background_color }};
    }
  {% endif %}
{%- endstyle -%}

<section class="divine-wholesale">
  <div class="divine-wholesale__grid">
    <div class="divine-wholesale__image">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '375, 550, 750, 900',
            sizes: '(min-width: 768px) 50vw, 100vw'
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="divine-wholesale__content">
      {%- if section.settings.caption != blank -%}
        <span class="divine-section-label">{{ section.settings.caption }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="divine-wholesale__text">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="divine-wholesale__ctas">
        {%- if section.settings.button_label_1 != blank -%}
          <a href="{{ section.settings.button_link_1 }}" class="divine-btn divine-btn-primary">{{ section.settings.button_label_1 }}</a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="divine-btn divine-btn-secondary">{{ section.settings.button_label_2 }}</a>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="divine-wholesale__features">
          {%- for block in section.blocks -%}
            <div class="divine-wholesale__feature" {{ block.shopify_attributes }}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>{{ block.settings.text }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .divine-wholesale {
    padding: 48px 20px;
  }
  .divine-wholesale__grid {
    max-width: 1200px;
    margin: 0 auto;
  }
  .divine-wholesale__image {
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
    margin-bottom: 32px;
  }
  .divine-wholesale__image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .divine-wholesale__content h2 {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 400;
    margin: 8px 0 16px;
    line-height: 1.3;
  }
  .divine-wholesale__text {
    font-size: 1.7rem;
    color: var(--color-text-muted, #666);
    line-height: 1.7;
    margin-bottom: 24px;
  }
  .divine-wholesale__text p {
    margin-bottom: 12px;
  }
  .divine-wholesale__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 28px;
  }
  .divine-wholesale__features {
    display: grid;
    gap: 12px;
  }
  .divine-wholesale__feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
  }
  .divine-wholesale__feature svg {
    width: 18px;
    height: 18px;
    stroke: var(--color-accent-dark, #7c6c5b);
    flex-shrink: 0;
  }
  @media screen and (min-width: 768px) {
    .divine-wholesale__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .divine-wholesale__image {
      margin-bottom: 0;
    }
    .divine-wholesale__content h2 {
      font-size: 30px;
    }
  }
</style>

{% schema %}
{
  "name": "Divine Wholesale",
  "tag": "section",
  "class": "divine-wholesale-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "B2B & Private Label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Launch Your Own Organic Tea or Superfood Brand"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Partner with Divine Ingredients for wholesale pricing, private label solutions, and custom blending. We supply cafés, wellness brands, retailers, and entrepreneurs with premium organic ingredients.</p>"
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary button label",
      "default": "Start a Private Label Project"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "default": "Request Wholesale Pricing"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": -48,
      "max": 100,
      "step": 4,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "Low minimum order quantities"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Divine Wholesale",
      "blocks": [
        { "type": "feature", "settings": { "text": "Low minimum order quantities" } },
        { "type": "feature", "settings": { "text": "Custom private label packaging" } },
        { "type": "feature", "settings": { "text": "All products USDA Organic certified" } },
        { "type": "feature", "settings": { "text": "Dedicated account support" } }
      ]
    }
  ]
}
{% endschema %}
