{%- comment -%}
  Chai Edit pop-up modal.

  Opens on click of ANY element with [data-open-chai-popup]; closes on the X,
  on overlay click, or Esc. Accessible: role="dialog", aria-modal, focus trap,
  focus restore. Does NOT auto-open — click only.

  Optional params (all have sensible defaults matching the Chai Edit section):
    id            - element id (default 'ChaiEditPopup')
    heading       - modal heading HTML
    intro         - short intro line
    blends        - blend lines separated by '|'
    button_label  - CTA label
    button_link   - CTA link
{%- endcomment -%}
{%- liquid
  assign popup_id = id | default: 'ChaiEditPopup'
  assign popup_heading = heading | default: 'The <em>Chai Edit</em>'
  assign popup_intro = intro | default: 'Three iconic blends, one moment of calm — Mumbai Masala, Tulsi, and Herbal Chai.'
  assign popup_btn_label = button_label | default: 'Get the Chai Edit'
  assign popup_btn_link = button_link | default: '/products/the-chai-edit'
  assign blend_src = blends | default: 'Mumbai Masala Chai · Bold & spiced black tea|Tulsi Chai · Holy basil infusion, soothing & refreshing|Herbal Chai · Caffeine-free, calm & comforting'
  assign blend_lines = blend_src | split: '|'
-%}

{%- style -%}
  .d-chai-modal[hidden]{ display: none; }
  .d-chai-modal{
    position: fixed; inset: 0; z-index: 1000;
    display: flex; align-items: center; justify-content: center; padding: 20px;
  }
  .d-chai-modal__overlay{
    position: absolute; inset: 0;
    background: rgba(17,20,16,.62);
  }
  .d-chai-modal__dialog{
    position: relative; z-index: 1;
    background: var(--d-forest); color: var(--d-beige-lt);
    width: 100%; max-width: 440px; padding: 44px 38px 40px;
    border-radius: 4px; box-shadow: 0 24px 80px rgba(0,0,0,.4);
    text-align: center;
  }
  .d-chai-modal__close{
    position: absolute; top: 12px; right: 14px;
    background: none; border: none; color: var(--d-beige-lt);
    font-size: 26px; line-height: 1; cursor: pointer; opacity: .7; padding: 4px 8px;
  }
  .d-chai-modal__close:hover{ opacity: 1; }
  .d-chai-modal__kicker{
    font-family: var(--d-font-sans); font-size: 11px; font-weight: 500;
    letter-spacing: .14em; text-transform: uppercase; opacity: .7; margin: 0 0 12px;
  }
  .d-chai-modal__title{
    font-family: var(--d-font-serif); font-size: 34px; font-weight: 300;
    line-height: 1.1; margin: 0 0 14px;
  }
  .d-chai-modal__title em{ font-style: italic; }
  .d-chai-modal__intro{
    font-family: var(--d-font-sans); font-size: 15px; font-weight: 300;
    line-height: 1.6; opacity: .85; margin: 0 0 22px;
  }
  .d-chai-modal__blends{
    list-style: none; margin: 0 0 30px; padding: 0;
    display: flex; flex-direction: column; gap: 12px; text-align: left;
  }
  .d-chai-modal__blends li{
    font-family: var(--d-font-sans); font-size: 14px; font-weight: 300;
    line-height: 1.5; padding-left: 18px; position: relative;
  }
  .d-chai-modal__blends li::before{
    content: ''; position: absolute; left: 0; top: 8px;
    width: 6px; height: 6px; border-radius: 50%; background: var(--d-beige);
  }
{%- endstyle -%}

<div class="d-chai-modal" id="{{ popup_id }}" hidden>
  <div class="d-chai-modal__overlay" data-close-chai-popup></div>
  <div class="d-chai-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="{{ popup_id }}-title">
    <button type="button" class="d-chai-modal__close" data-close-chai-popup aria-label="Close">&times;</button>
    <p class="d-chai-modal__kicker">New from Divine Ingredients</p>
    <h2 class="d-chai-modal__title" id="{{ popup_id }}-title">{{ popup_heading }}</h2>
    {%- if popup_intro != blank -%}<p class="d-chai-modal__intro">{{ popup_intro }}</p>{%- endif -%}
    <ul class="d-chai-modal__blends">
      {%- for line in blend_lines -%}
        {%- assign l = line | strip -%}
        {%- if l != blank -%}<li>{{ l }}</li>{%- endif -%}
      {%- endfor -%}
    </ul>
    <a href="{{ popup_btn_link }}" class="d-btn-hp">{{ popup_btn_label }}</a>
  </div>
</div>

<script>
  (function(){
    var modal = document.getElementById('{{ popup_id }}');
    if (!modal || modal.dataset.bound) return;
    modal.dataset.bound = '1';
    var lastFocus = null;
    function focusable(){
      return modal.querySelectorAll('a[href],button:not([disabled]),input,textarea,select,[tabindex]:not([tabindex="-1"])');
    }
    function onKey(e){
      if (e.key === 'Escape') { closeModal(); return; }
      if (e.key === 'Tab') {
        var f = focusable(); if (!f.length) return;
        var first = f[0], last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
    function openModal(trigger){
      lastFocus = trigger || document.activeElement;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      var f = focusable(); if (f.length) f[0].focus();
      document.addEventListener('keydown', onKey);
    }
    function closeModal(){
      modal.hidden = true;
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKey);
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }
    document.addEventListener('click', function(e){
      var opener = e.target.closest('[data-open-chai-popup]');
      if (opener) { e.preventDefault(); openModal(opener); return; }
      if (e.target.closest('[data-close-chai-popup]')) { e.preventDefault(); closeModal(); }
    });
  })();
</script>
