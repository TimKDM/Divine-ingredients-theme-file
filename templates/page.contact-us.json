{
  "sections": {
    "main": {
      "type": "main-page",
      "disabled": true,
      "settings": {
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "hero": {
      "type": "rich-text",
      "blocks": {
        "caption": {
          "type": "caption",
          "settings": {
            "caption": "Say Hello",
            "text_style": "caption-with-letter-spacing",
            "text_size": "medium"
          }
        },
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "<p>We're Real People. <em>Let's Talk.</em></p>",
            "heading_size": "large",
            "heading_style": "default",
            "heading_tag": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Questions about our sourcing, an order, a sample, or a wholesale partnership? Every email lands in a real inbox — no chatbots, no ticket queues. We reply personally, usually within 24 hours.</p>"
          }
        }
      },
      "block_order": ["caption", "heading", "text"],
      "settings": {
        "desktop_content_position": "center",
        "content_alignment": "center",
        "color_scheme": "option-2",
        "padding_top": 64,
        "padding_bottom": 32
      }
    },
    "methods": {
      "type": "multicolumn",
      "blocks": {
        "email": {
          "type": "column",
          "settings": {
            "hide_image": true,
            "title": "Email Us",
            "text": "<p>orders@divineingredients.com</p><p>Sent to a real person — typically a reply within 24 hours.</p>",
            "link_label": "Send an email",
            "link": "mailto:orders@divineingredients.com"
          }
        },
        "samples": {
          "type": "column",
          "settings": {
            "hide_image": true,
            "title": "Request a Sample",
            "text": "<p>Trying us out before committing to a full bag or a bulk order? We'll send a sample so you can taste the difference for yourself.</p>",
            "link_label": "Email a sample request",
            "link": "mailto:orders@divineingredients.com?subject=Sample%20Request"
          }
        }
      },
      "block_order": ["email", "samples"],
      "settings": {
        "title": "Get in Touch",
        "heading_size": "medium",
        "heading_tag": "h2",
        "columns_desktop": 2,
        "columns_mobile": "1",
        "column_alignment": "center",
        "color_scheme": "option-1",
        "padding_top": 32,
        "padding_bottom": 32
      }
    },
    "certs": {
      "type": "divine-cert-bar",
      "blocks": {
        "usda": { "type": "cert", "settings": { "icon": "usda", "label": "USDA Organic" } },
        "ccof": { "type": "cert", "settings": { "icon": "ccof", "label": "CCOF Certified" } },
        "non_gmo": { "type": "cert", "settings": { "icon": "non-gmo", "label": "Non-GMO" } },
        "lab": { "type": "cert", "settings": { "icon": "lab-tested", "label": "Lab Tested" } },
        "vegan": { "type": "cert", "settings": { "icon": "vegan", "label": "Vegan" } }
      },
      "block_order": ["usda", "ccof", "non_gmo", "lab", "vegan"],
      "settings": {
        "padding_top": 24,
        "padding_bottom": 24
      }
    },
    "contact-form": {
      "type": "contact-form",
      "settings": {
        "contact_style": "column",
        "hide_image": true,
        "caption": "",
        "text_style": "caption-with-letter-spacing",
        "text_size": "medium",
        "heading": "Send Us a Message",
        "heading_size": "medium",
        "heading_style": "default",
        "heading_tag": "h2",
        "text": "<p>Tell us about your order, a question on sourcing, a sample request, or anything else. The more detail, the faster we can help.</p>",
        "full_width": false,
        "hide_phone_field": false,
        "all_fields_required": false,
        "color_scheme": "option-2",
        "padding_top": 32,
        "padding_bottom": 32
      }
    },
    "quick-help": {
      "type": "multicolumn",
      "blocks": {
        "track": {
          "type": "column",
          "settings": {
            "hide_image": true,
            "title": "Track Your Order",
            "text": "<p>Check status, shipping, and delivery details for a recent order.</p>",
            "link_label": "View orders",
            "link": "/account/orders"
          }
        },
        "shipping": {
          "type": "column",
          "settings": {
            "hide_image": true,
            "title": "Shipping & Returns",
            "text": "<p>How we ship, what to expect, and our straightforward return policy.</p>",
            "link_label": "Read policy",
            "link": "/policies/shipping-policy"
          }
        },
        "faq": {
          "type": "column",
          "settings": {
            "hide_image": true,
            "title": "Sourcing & FAQ",
            "text": "<p>Where our ingredients come from, how we test for purity, and answers to common questions.</p>",
            "link_label": "Browse FAQ",
            "link": "/pages/faq"
          }
        }
      },
      "block_order": ["track", "shipping", "faq"],
      "settings": {
        "title": "Looking for Something Specific?",
        "heading_size": "medium",
        "heading_tag": "h2",
        "columns_desktop": 3,
        "columns_mobile": "1",
        "column_alignment": "center",
        "color_scheme": "option-3",
        "padding_top": 48,
        "padding_bottom": 48
      }
    },
    "cta": {
      "type": "rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "<p>Thinking Wholesale?</p>",
            "heading_size": "medium",
            "heading_style": "default",
            "heading_tag": "h2"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>We partner with cafés, retailers, and private-label brands who want premium organic ingredients at scale — with the same sourcing transparency and lab documentation our retail customers get. Let's build something together.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "button_label": "Apply for Wholesale",
            "button_link": "/pages/wholesale",
            "button_style_secondary": false
          }
        }
      },
      "block_order": ["heading", "text", "button"],
      "settings": {
        "content_alignment": "center",
        "color_scheme": "option-4",
        "padding_top": 56,
        "padding_bottom": 56
      }
    }
  },
  "order": ["main", "hero", "methods", "certs", "contact-form", "quick-help", "cta"]
}
