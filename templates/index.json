        "value_4": {
          "type": "value",
          "settings": {
            "icon": "heart",
            "title": "Partners in Your Journey",
            "description": "Supporting creators, chefs, and wellness brands who demand the very best ingredients."
          }
        }
      },
      "block_order": ["value_1", "value_2", "value_3", "value_4"],
      "settings": {
        "image": "shopify:\/\/shop_images\/Smoothie-blog-image-2.jpg",
        "heading": "Extraordinary Creations Begin with Exceptional Ingredients",
        "text": "What started as a passion for pure, authentic ingredients has grown into a trusted source for creators who refuse to compromise on quality. We work directly with growers, producers, and artisans who share our commitment to excellence — ensuring that every ingredient bearing our name meets the highest standards of purity and authenticity.",
        "button_label": "Our Story",
        "button_link": "shopify:\/\/pages\/about-us"
      }
    },
    "divine_testimonials": {
      "type": "divine-testimonials",
      "blocks": {
        "testimonial_1": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "The ceremonial matcha is the best I've found outside of Japan. Our café customers always ask what brand we use. The consistency batch to batch is incredible.",
            "author": "Sarah M.",
            "role": "Café Owner, Portland"
          }
        },
        "testimonial_2": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Finally found a reliable source for organic turmeric and ashwagandha. The quality is consistent, the lab testing gives me confidence, and the bulk pricing is perfect for our formulations.",
            "author": "Dr. James K.",
            "role": "Wellness Practitioner"
          }
        },
        "testimonial_3": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "I switched all my baking ingredients to Divine and the difference is night and day. The vanilla, the cinnamon, the matcha — everything tastes more vibrant and real.",
            "author": "Michelle T.",
            "role": "Home Baker & Recipe Creator"
          }
        },
        "testimonial_4": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "We've been using Divine Ingredients for our private label tea line and couldn't be happier. The sourcing transparency and quality certifications make it easy to build trust with our own customers.",
            "author": "Ryan & Co.",
            "role": "Private Label Brand"
          }
        },
        "testimonial_5": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "The mushroom powder blends are outstanding — lion's mane and reishi that actually taste clean. No fillers, no weird aftertaste. My morning smoothie has never been better.",
            "author": "Anika P.",
            "role": "Wellness Coach, Vancouver"
          }
        }
      },
      "block_order": ["testimonial_1", "testimonial_2", "testimonial_3", "testimonial_4", "testimonial_5"],
      "settings": {
        "caption": "Trusted by Creators",
        "title": "What Our Community Says"
      }
    },
