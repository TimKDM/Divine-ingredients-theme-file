    "divine_testimonials": {
      "type": "divine-testimonials",
      "blocks": {
        "testimonial_1": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "I switched to Divine's ceremonial matcha six months ago and I'm picky about everything else now. Bright, grassy, never bitter — you can tell it hasn't been sitting on a shelf for a year. Mornings actually feel different.",
            "author": "Maya R.",
            "role": "Daily Matcha Drinker, Seattle WA",
            "source": "Google Review",
            "link": ""
          }
        },
        "testimonial_2": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Their turmeric is the only one I've tried that actually shows up in my joints. Bright, peppery, stains the spoon — the way real turmeric should. I take it daily after lifting and I can taste why it's a different product.",
            "author": "Marcus T.",
            "role": "Strength Athlete, Brooklyn NY",
            "source": "Google Review",
            "link": ""
          }
        },
        "testimonial_3": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "The chamomile-lavender blend is the closest thing to a sleep aid that actually works for me. Soft, real flowers in the cup — no perfume taste, no dust. I keep one tin on my nightstand and one at the office.",
            "author": "Olivia K.",
            "role": "Tea Ritualist, Madison WI",
            "source": "Google Review",
            "link": ""
          }
        },
        "testimonial_4": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Finally — a brand where I don't have to second-guess the ingredient list. The chamomile and lavender blend is part of my nightly routine now. Simple, honest, and it actually works.",
            "author": "David L.",
            "role": "Wellness Coach & Yoga Instructor",
            "source": "Google Review",
            "link": ""
          }
        },
        "testimonial_5": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "I make a smoothie every morning and I've gone through every adaptogen brand on Amazon. Divine's ashwagandha and moringa are the first I trust — third-party tested, no metallic finish, and they actually blend in instead of clumping at the bottom.",
            "author": "Priya S.",
            "role": "Daily Smoothie Maker, Oakland CA",
            "source": "Google Review",
            "link": ""
          }
        },
        "testimonial_6": {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Switched from a big grocery brand to Divine for all my baking — the cinnamon, the vanilla, the turmeric. Night and day. Everything just tastes more like the real thing because it is.",
            "author": "Michelle T.",
            "role": "Recipe Creator & Home Baker",
            "source": "Google Review",
            "link": ""
          }
        }
      },
